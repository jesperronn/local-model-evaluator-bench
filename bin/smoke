#!/usr/bin/env bash
# bin/smoke [model-id] — prove every installed CLI can actually drive a model
# through LM Studio. Loads a small model, runs the trivial smoke case across all
# adapters, and classifies each: PASS / PARTIAL (reached model, task incomplete)
# / FAIL (couldn't reach the model — a wiring problem).
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"; source "$HERE/lib/common.sh"

MODEL="${1:-$SMOKE_MODEL}"

lms_up || die "LM Studio not reachable at $LMS_BASE_URL (run: lms server start)"

# --- ensure the model is loaded with sufficient context ---------------------
loaded_ctx=$(lms ps --json 2>/dev/null \
  | python3 -c "
import json, sys
ps = json.load(sys.stdin)
ctxs = [p.get('contextLength', 0) for p in ps if p.get('modelKey') == '$MODEL']
print(max(ctxs) if ctxs else 0)
" 2>/dev/null || echo 0)

if [ "${loaded_ctx:-0}" -ge "${SMOKE_CTX}" ] 2>/dev/null; then
  ok "model already loaded: $MODEL (ctx ${loaded_ctx})"
else
  if [ "${loaded_ctx:-0}" -gt 0 ] 2>/dev/null; then
    info "model loaded at ctx ${loaded_ctx} < ${SMOKE_CTX} required — reloading with ${SMOKE_CTX} ..."
    lms unload "$MODEL" >/dev/null 2>&1 || true
  fi
  info "loading $MODEL (ttl ${SMOKE_TTL:-none}s, ctx ${SMOKE_CTX}) ..."
  ensure_model_loaded "$MODEL" "${SMOKE_TTL:-}" "${SMOKE_CTX}" \
    && ok "loaded $MODEL" \
    || die "could not load $MODEL — check 'lms ls' for the exact key, or load it in the GUI"
fi

# --- run the smoke case across every adapter --------------------------------
info "running smoke case across adapters: $DEFAULT_ADAPTERS"
echo
"$HERE/bin/bench" --cases smoke-00-hello --models "$MODEL" --timeout 120

# --- classify the just-written results --------------------------------------
CSV="$(ls -dt "$RESULTS_DIR"/*/results.csv 2>/dev/null | head -1)"
[ -f "$CSV" ] || die "no results produced"

echo
echo "${C_BLD}Smoke verdict — can each tool reach '$MODEL'?${C_RST}"
fails=0
while IFS=, read -r adapter model case pass total score seconds status trials; do
  [ "$adapter" = adapter ] && continue
  if [ "$status" != ok ]; then
    err "$(printf '%-9s FAIL    — could not reach model (%s)' "$adapter" "$status")"; fails=$((fails+1))
  elif [ "$pass" = "$total" ]; then
    ok  "$(printf '%-9s PASS    — full path works (%ss)' "$adapter" "$seconds")"
  else
    warn "$(printf '%-9s PARTIAL — reached model, task incomplete (%s/%s)' "$adapter" "$pass" "$total")"
  fi
done < "$CSV"

echo
if [ "$fails" -eq 0 ]; then
  ok "all installed tools reached the model — ready to benchmark"
else
  warn "$fails tool(s) could not reach the model — check that adapter's flags in adapters/ (see docs/SETUP.md)"
fi
echo "${C_DIM}logs + edits: $(dirname "$CSV")/sandbox/<adapter>/...  •  details: $CSV${C_RST}"
exit "$([ "$fails" -eq 0 ] && echo 0 || echo 1)"
