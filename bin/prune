#!/usr/bin/env bash
# bin/prune — list and permanently remove downloaded models.
# Supports lms (LM Studio), ollama, and mlx runtimes.
# Listing is safe; deletion requires --interactive (fzf picker).

set -euo pipefail

HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"
source "$HERE/lib/common.sh"

RUNTIME=all
DRY_RUN=false
INTERACTIVE=false
UNUSED=false

HF_CACHE="${HOME}/.cache/huggingface/hub"

DIM='\033[2m'
BOLD='\033[1m'
GREEN_BOLD='\033[1;32m'
RED_BOLD='\033[1;31m'
RESET='\033[0m'

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

List and permanently remove downloaded models.
Without --interactive, prints a table and exits (no deletion).

Options:
  --runtime=RT        Filter to a single runtime: lms, ollama, mlx, all (default: all)
  -i, --interactive   Pick models to remove via fzf, then delete
  --unused            Only show/offer models NOT referenced by the bench lists
                      (models.txt, models-mlx.txt, models-ollama.txt, aliases)
  --dry-run           With --interactive: preview what would be removed
  -h, --help          Show this help

Last-used sources:
  lms     Loaded models: from lms ps --json (lastUsedTime); unloaded: dir mtime
  ollama  Manifest file mtime
  mlx     Model dir mtime
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --runtime=*)       RUNTIME="${1#--runtime=}" ;;
    --runtime)         RUNTIME="${2:?--runtime requires a value}"; shift ;;
    -i|--interactive)  INTERACTIVE=true ;;
    --unused)          UNUSED=true ;;
    --dry-run)         DRY_RUN=true ;;
    --help|-h)         usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

case "$RUNTIME" in lms|ollama|mlx|all) ;; *) die "unknown runtime: $RUNTIME" ;; esac

# ── helpers ───────────────────────────────────────────────────────────────────

fmt_bytes() {
  awk -v b="$1" 'BEGIN{
    if (b>=1073741824) printf "%.1fG", b/1073741824
    else if (b>=1048576) printf "%.1fM", b/1048576
    else printf "%dK", b/1024
  }'
}

fmt_age_s() {
  local s="${1:-0}"
  (( s == 0 )) && { printf "—"; return; }
  local diff=$(( $(date +%s) - s ))
  if   (( diff <= 0    )); then printf "just now"
  elif (( diff < 3600  )); then printf "%dm ago" $(( diff / 60 ))
  elif (( diff < 86400 )); then printf "%dh ago" $(( diff / 3600 ))
  elif (( diff < 604800)); then printf "%dd ago" $(( diff / 86400 ))
  else                          printf "%dw ago" $(( diff / 604800 ))
  fi
}

path_mtime() { stat -f "%m" "$1" 2>/dev/null || echo 0; }
dir_bytes()  { du -sk "$1" 2>/dev/null | awk '{print $1*1024}' || echo 0; }

# ── collectors ────────────────────────────────────────────────────────────────
# Each outputs TSV rows: runtime<TAB>model_id<TAB>size_bytes<TAB>last_used_s<TAB>delete_target

collect_lms() {
  command -v lms >/dev/null 2>&1 || { warn "lms not found — skipping lms runtime"; return; }

  # Resolve modelKey → concrete weights dir using LM Studio's own index
  # (~/.lmstudio/.internal/model-index-cache.json), the authoritative source of
  # truth — no filename/token guessing. Each emitted row is one concrete weights
  # directory; the delete target lists the concrete dir plus any tiny hub-pointer
  # dir (pipe-separated) so both are removed together. Also surfaces orphan dirs
  # on disk that the index doesn't reference (e.g. unsupported/stale downloads).
  #
  # Outputs TSV: model_id  size_bytes  last_used_s  delete_target(s, '|'-joined)
  python3 <<'PYEOF' | awk -F'\t' 'OFS="\t"{print "lms",$1,$2,$3,$4}'
import json, subprocess, sys
from pathlib import Path

home        = Path.home()
index_path  = home / ".lmstudio/.internal/model-index-cache.json"
comm_root   = home / ".lmstudio/models/lmstudio-community"

try:
    ps_models = json.loads(subprocess.check_output(["lms", "ps", "--json"], stderr=subprocess.DEVNULL))
except Exception:
    ps_models = []
# lastUsedTime (ms) for currently-loaded models, keyed by modelKey
loaded = {m.get("modelKey"): (m.get("lastUsedTime") or 0) for m in ps_models}

if not index_path.exists():
    sys.exit(0)
with open(index_path) as f:
    index = json.load(f)

# Group every index entry by its concrete weights dir, so the hub virtual model
# and the bare community entry collapse into a single deletable unit.
groups = {}  # concrete_dir -> {ids:set, pointers:set, size:int, mtime_ms:int}
for m in index.get("models", []):
    concrete = m.get("concreteModelDirAbsolutePath") or m.get("containingDirAbsolutePath")
    if not concrete:
        continue
    g = groups.setdefault(concrete, {"ids": set(), "pointers": set(), "size": 0, "mtime": 0})
    for ident in m.get("autoIdentifiers", []) or []:
        if "/" in ident and "@" not in ident:   # prefer publisher/key form, skip quant aliases
            g["ids"].add(ident)
    container = m.get("containingDirAbsolutePath")
    if container and container != concrete:
        g["pointers"].add(container)            # tiny hub-pointer dir
    g["size"]  = max(g["size"], m.get("sizeBytes", 0))
    g["mtime"] = max(g["mtime"], m.get("containingDirMtime", 0))

referenced = set(groups.keys())

# A hub pointer dir can be shared by sibling variants (e.g. qwen3-coder-30b
# @4bit and @8bit). Only delete a pointer alongside a concrete dir when it is
# uniquely owned, otherwise removing one variant would break the sibling.
ptr_owners = {}
for concrete, g in groups.items():
    for p in g["pointers"]:
        ptr_owners.setdefault(p, set()).add(concrete)
for concrete, g in groups.items():
    g["pointers"] = {p for p in g["pointers"] if len(ptr_owners[p]) == 1}

def best_id(ids, concrete):
    if ids:
        return sorted(ids, key=len)[0]
    return Path(concrete).name

for concrete, g in sorted(groups.items()):
    if not Path(concrete).exists():   # index cache is stale after a deletion — trust disk
        continue
    mid     = best_id(g["ids"], concrete)
    # last-used: prefer loaded lastUsedTime, else concrete dir mtime, else index mtime
    ts_ms   = 0
    for ident in g["ids"]:
        ts_ms = max(ts_ms, loaded.get(ident, 0))
    if ts_ms == 0:
        p = Path(concrete)
        if p.exists():
            ts_ms = int(p.stat().st_mtime * 1000)
        else:
            ts_ms = g["mtime"]
    targets = "|".join([concrete, *sorted(g["pointers"])])
    print(f"{mid}\t{g['size']}\t{int(ts_ms/1000)}\t{targets}")

# Orphans: weights dirs on disk the index never references (unsupported arch,
# stale/interrupted downloads). These are pure reclaimable space.
if comm_root.exists():
    for d in sorted(comm_root.iterdir()):
        if not d.is_dir() or str(d) in referenced:
            continue
        try:
            size = sum(f.stat().st_size for f in d.rglob("*") if f.is_file())
        except OSError:
            size = 0
        print(f"(orphan) {d.name}\t{size}\t{int(d.stat().st_mtime * 1000)}\t{d}")
PYEOF
}

collect_ollama() {
  command -v ollama >/dev/null 2>&1 || { warn "ollama not found — skipping ollama runtime"; return; }

  local manifest_root="${HOME}/.ollama/models/manifests"

  ollama list 2>/dev/null | awk 'NR>1' | while read -r name _id size unit _rest; do
    local size_bytes=0
    case "$unit" in
      GB) size_bytes=$(awk -v s="$size" 'BEGIN{printf "%.0f", s*1073741824}') ;;
      MB) size_bytes=$(awk -v s="$size" 'BEGIN{printf "%.0f", s*1048576}') ;;
    esac
    local tag="${name##*:}" ns="${name%%:*}"
    local mpath
    mpath=$(find "$manifest_root" -name "$tag" -path "*/${ns}/*" 2>/dev/null | head -1 || true)
    local last_used_s=0
    [ -n "$mpath" ] && last_used_s=$(path_mtime "$mpath")
    echo "ollama	$name	$size_bytes	$last_used_s	$name"
  done
}

collect_mlx() {
  local models_file="${HERE}/models-mlx.txt"
  [ -f "$models_file" ] || { warn "models-mlx.txt not found — skipping mlx runtime"; return; }

  while IFS= read -r model; do
    local dir
    if [[ "$model" == /* ]]; then
      dir="$model"
    else
      # HuggingFace id: mlx-community/Foo → ~/.cache/huggingface/hub/models--mlx-community--Foo
      dir="${HF_CACHE}/models--${model//\//--}"
    fi

    local size_bytes=0 last_used_s=0
    if [ -d "$dir" ]; then
      size_bytes=$(dir_bytes "$dir")
      last_used_s=$(path_mtime "$dir")
    fi
    echo "mlx	$model	$size_bytes	$last_used_s	$dir"
  done < <(read_list "$models_file")
}

# ── gather all entries ────────────────────────────────────────────────────────
# TSV: runtime  model_id  size_bytes  last_used_s  delete_target

gather_entries() {
  case "$RUNTIME" in
    lms)    collect_lms ;;
    ollama) collect_ollama ;;
    mlx)    collect_mlx ;;
    all)    collect_lms; collect_ollama; collect_mlx ;;
  esac
}

entries_tsv=$(gather_entries)

# ── --unused filter ─────────────────────────────────────────────────────────
# Keep only entries NOT referenced by any bench list. A model counts as "used"
# if its id, any delete-target path, or that path's basename appears in:
#   models.txt, models-ollama.txt (publisher/key ids)
#   models-mlx.txt               (absolute concrete dir paths)
#   models-aliases.conf          (target column)

build_used() {
  local f
  for f in models.txt models-ollama.txt models-mlx.txt; do
    [[ -f "$HERE/$f" ]] && grep -vE '^[[:space:]]*#|^[[:space:]]*$' "$HERE/$f"
  done
  [[ -f "$HERE/models-aliases.conf" ]] && awk '!/^[[:space:]]*#/ && NF>=2 {print $2}' "$HERE/models-aliases.conf"
}

# Match is by exact id/path/basename first; then a token-subset fallback so a
# freshly-downloaded model not yet in LM Studio's index (shown by its dir name,
# e.g. "Devstral-2-123B-Instruct-2512-GGUF") still matches its bench-list id
# ("mistralai/devstral-2-2512"). This avoids flagging wanted models as unused.
filter_unused() {
  UNUSED_USED="$(build_used)" ENTRIES="$entries_tsv" python3 <<'PYEOF'
import os, re
def toks(s): return set(re.findall(r"[a-z0-9]+", s.lower()))
used = [u.strip() for u in os.environ["UNUSED_USED"].splitlines() if u.strip()]
used_exact = set(used)
used_base  = {os.path.basename(u) for u in used}
used_tok   = [toks(u.split("/")[-1]) for u in used]

for line in os.environ["ENTRIES"].splitlines():
    if not line.strip():
        continue
    rt, mid, size, ts, target = line.split("\t")
    paths = [p for p in target.split("|") if p]
    is_used = (mid in used_exact
               or any(p in used_exact or os.path.basename(p) in used_base for p in paths))
    if not is_used:
        cand = [toks(mid.split("/")[-1])] + [toks(os.path.basename(p)) for p in paths]
        is_used = any(ut and any(ut <= ct for ct in cand) for ut in used_tok)
    if not is_used:
        print(line)
PYEOF
}

if $UNUSED; then
  entries_tsv=$(filter_unused)
fi

if [[ -z "$entries_tsv" ]]; then
  $UNUSED && { echo "No unused models — everything on disk is referenced by a bench list."; exit 0; }
  echo "No models found."
  exit 0
fi

# ── display table ─────────────────────────────────────────────────────────────

print_table() {
  printf "${BOLD}%-8s  %-7s  %-10s  %s${RESET}\n" "Runtime" "Size" "Last used" "Model"
  printf '%0.s─' {1..80}; echo
  while IFS=$'\t' read -r rt id size last_used_s _target; do
    local size_str last_str
    size_str=$(fmt_bytes "$size")
    last_str=$(fmt_age_s "$last_used_s")
    printf "%-8s  %-7s  %-10s  %s\n" "[$rt]" "$size_str" "$last_str" "$id"
  done <<< "$entries_tsv"
}

# ── interactive fzf picker ────────────────────────────────────────────────────

do_interactive() {
  command -v fzf >/dev/null 2>&1 || die "fzf not installed (brew install fzf)"

  local fzf_lines=()
  while IFS=$'\t' read -r rt id size last_used_s _target; do
    local size_str last_str
    size_str=$(fmt_bytes "$size")
    last_str=$(fmt_age_s "$last_used_s")
    fzf_lines+=("$(printf "%-8s  %-7s  %-10s  %s" "[$rt]" "$size_str" "$last_str" "$id")")
  done <<< "$entries_tsv"

  local selected
  selected=$(printf '%s\n' "${fzf_lines[@]}" | \
    fzf --multi \
        --prompt='Remove > ' \
        --header='TAB = toggle  ENTER = confirm  ESC = cancel' \
        2>/dev/null || true)

  [[ -z "$selected" ]] && { echo "Nothing selected."; return; }

  # Recover TSV rows by matching model id from fzf selection.
  # Extract everything after the last double-space separator (model ID is the last field).
  local to_remove=()
  while IFS= read -r line; do
    local sel_id="${line##*  }"
    sel_id="${sel_id#"${sel_id%%[![:space:]]*}"}"
    local rt row_id size ts target
    while IFS=$'\t' read -r rt row_id size ts target; do
      [[ "$row_id" == "$sel_id" ]] && to_remove+=("$rt	$row_id	$target") && break
    done <<< "$entries_tsv"
  done <<< "$selected"

  (( ${#to_remove[@]} == 0 )) && { echo "Nothing matched."; return; }

  # Align OK/FAILED column
  local max_len=0
  for entry in "${to_remove[@]}"; do
    local rt id _t
    IFS=$'\t' read -r rt id _t <<< "$entry"
    local plain="Removing [$rt] $id..."
    (( ${#plain} > max_len )) && max_len=${#plain}
  done

  for entry in "${to_remove[@]}"; do
    local rt id target
    IFS=$'\t' read -r rt id target <<< "$entry"
    local plain="Removing [$rt] $id..."
    local pad=$(( max_len - ${#plain} ))

    printf "${DIM}Removing${RESET} ${BOLD}[%s]${RESET} %s..." "$rt" "$id"

    if $DRY_RUN; then
      printf "%*s${GREEN_BOLD}dry-run${RESET}\n" $(( pad + 1 )) ""
      continue
    fi

    local ok=false
    case "$rt" in
      lms)
        if [[ -z "$target" ]]; then
          ok=false
        else
          # Unload from memory first if resident (best-effort; skip for orphans)
          if [[ "$id" != "(orphan) "* ]]; then
            lms ps --json 2>/dev/null \
              | jq -e --arg k "$id" '.[] | select(.modelKey==$k)' >/dev/null 2>&1 \
              && lms unload "$id" >/dev/null 2>&1 || true
          fi
          # target may be several '|'-joined dirs (concrete weights + hub pointer)
          ok=true
          local _oldifs="$IFS" path
          IFS='|'
          for path in $target; do
            IFS="$_oldifs"
            [[ -n "$path" && -e "$path" ]] && { rm -rf "$path" || ok=false; }
          done
          IFS="$_oldifs"
        fi
        ;;
      ollama)
        ollama rm "$target" >/dev/null 2>&1 && ok=true
        ;;
      mlx)
        [[ -d "$target" ]] && rm -rf "$target" && ok=true
        ;;
    esac

    if $ok; then
      printf "%*s${GREEN_BOLD}OK${RESET}\n" $(( pad + 1 )) ""
    else
      printf "%*s${RED_BOLD}FAILED${RESET}\n" $(( pad + 1 )) ""
    fi
  done
}

# ── main ──────────────────────────────────────────────────────────────────────

if $INTERACTIVE; then
  do_interactive
else
  $DRY_RUN && printf "${DIM}(dry-run — use --interactive to select models for removal)${RESET}\n\n"
  print_table
  echo
  total=$(echo "$entries_tsv" | wc -l | tr -d ' ')
  total_bytes=$(echo "$entries_tsv" | awk -F'\t' '{sum+=$3} END{print sum+0}')
  printf "${DIM}%d models, %s total${RESET}\n" "$total" "$(fmt_bytes "$total_bytes")"
fi
