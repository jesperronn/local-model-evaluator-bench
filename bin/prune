#!/usr/bin/env bash
# bin/prune — list and permanently remove downloaded models.
# Supports lms (LM Studio), ollama, and mlx runtimes.
# Listing is safe; deletion requires --interactive (fzf picker).

set -euo pipefail

HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"
source "$HERE/lib/common.sh"

RUNTIME=all
DRY_RUN=false
INTERACTIVE=false

HF_CACHE="${HOME}/.cache/huggingface/hub"

DIM='\033[2m'
BOLD='\033[1m'
GREEN_BOLD='\033[1;32m'
RED_BOLD='\033[1;31m'
RESET='\033[0m'

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

List and permanently remove downloaded models.
Without --interactive, prints a table and exits (no deletion).

Options:
  --runtime=RT        Filter to a single runtime: lms, ollama, mlx, all (default: all)
  -i, --interactive   Pick models to remove via fzf, then delete
  --dry-run           With --interactive: preview what would be removed
  -h, --help          Show this help

Last-used sources:
  lms     Loaded models: from lms ps --json (lastUsedTime); unloaded: dir mtime
  ollama  Manifest file mtime
  mlx     Model dir mtime
EOF
}

for arg in "$@"; do
  case "$arg" in
    --runtime=*)       RUNTIME="${arg#--runtime=}" ;;
    -i|--interactive)  INTERACTIVE=true ;;
    --dry-run)         DRY_RUN=true ;;
    --help|-h)         usage; exit 0 ;;
    *) echo "Unknown option: $arg" >&2; usage >&2; exit 1 ;;
  esac
done

case "$RUNTIME" in lms|ollama|mlx|all) ;; *) die "unknown runtime: $RUNTIME" ;; esac

# ── helpers ───────────────────────────────────────────────────────────────────

fmt_bytes() {
  awk -v b="$1" 'BEGIN{
    if (b>=1073741824) printf "%.1fG", b/1073741824
    else if (b>=1048576) printf "%.1fM", b/1048576
    else printf "%dK", b/1024
  }'
}

fmt_age_s() {
  local s="${1:-0}"
  (( s == 0 )) && { printf "—"; return; }
  local diff=$(( $(date +%s) - s ))
  if   (( diff <= 0    )); then printf "just now"
  elif (( diff < 3600  )); then printf "%dm ago" $(( diff / 60 ))
  elif (( diff < 86400 )); then printf "%dh ago" $(( diff / 3600 ))
  elif (( diff < 604800)); then printf "%dd ago" $(( diff / 86400 ))
  else                          printf "%dw ago" $(( diff / 604800 ))
  fi
}

path_mtime() { stat -f "%m" "$1" 2>/dev/null || echo 0; }
dir_bytes()  { du -sk "$1" 2>/dev/null | awk '{print $1*1024}' || echo 0; }

# ── collectors ────────────────────────────────────────────────────────────────
# Each outputs TSV rows: runtime<TAB>model_id<TAB>size_bytes<TAB>last_used_s<TAB>delete_target

collect_lms() {
  command -v lms >/dev/null 2>&1 || { warn "lms not found — skipping lms runtime"; return; }

  # Python resolves modelKey → disk directory (same heuristic as bin/lms_update).
  # Outputs TSV: key  size_bytes  last_used_s  disk_dir
  python3 <<'PYEOF' | awk -F'\t' 'OFS="\t"{print "lms",$1,$2,$3,$4}'
import json, re, subprocess, sys
from pathlib import Path

try:
    lms_models = json.loads(subprocess.check_output(["lms", "ls", "--json"], stderr=subprocess.DEVNULL))
    ps_models  = json.loads(subprocess.check_output(["lms", "ps",  "--json"], stderr=subprocess.DEVNULL))
except Exception:
    sys.exit(0)

loaded      = {m["modelKey"]: m.get("lastUsedTime") or 0 for m in ps_models}
models_root = Path.home() / ".lmstudio/models/lmstudio-community"
cache_path  = Path.home() / ".lmstudio/.internal/gguf-metadata-cache.json"

quant_map = {}
for m in lms_models:
    sv = m.get("selectedVariant", "")
    quant_map[m["modelKey"]] = sv.split("@")[1].lower() if "@" in sv else ""
is_mlx = {m["modelKey"]: m.get("format", "") == "safetensors" for m in lms_models}

def score(hf_dir, key):
    hf_t  = set(re.findall(r"[a-z0-9]+", hf_dir.lower()))
    key_t = set(re.findall(r"[a-z0-9]+", key.lower()))
    if ("qat" in hf_t) != ("qat" in key_t): return -1
    if ("mlx" in hf_t) != is_mlx.get(key, False): return -1
    return len(hf_t & key_t)

key_to_dir = {}

if cache_path.exists():
    with open(cache_path) as f:
        cache = json.load(f)
    for path_str, _ in cache["json"]["map"]:
        if "lmstudio-community" not in path_str: continue
        rel    = path_str.split("lmstudio-community/")[1]
        hf_dir = rel.split("/")[0]
        fname  = Path(rel).name
        m = re.search(r"[_-](Q\d[^._-]*(?:[_-][KkMm]+)*)\.gguf$", fname, re.IGNORECASE)
        if not m: continue
        quant = m.group(1).lower().replace("-", "_")
        best, best_s = None, 0
        for mod in lms_models:
            k = mod["modelKey"]
            if quant_map[k] != quant: continue
            s = score(hf_dir, k)
            if s > best_s: best_s, best = s, k
        if best and best_s >= 3:
            key_to_dir[best] = hf_dir

if models_root.exists():
    for dir_path in sorted(models_root.iterdir()):
        hf_dir = dir_path.name
        if any(v == hf_dir for v in key_to_dir.values()): continue
        best, best_s = None, 0
        for mod in lms_models:
            s = score(hf_dir, mod["modelKey"])
            if s > best_s: best_s, best = s, mod["modelKey"]
        if best and best_s >= 3 and best not in key_to_dir:
            key_to_dir[best] = hf_dir

for m in lms_models:
    key     = m["modelKey"]
    size    = m.get("sizeBytes", 0)
    hf_dir  = key_to_dir.get(key, "")
    disk    = str(models_root / hf_dir) if hf_dir else ""
    ts_ms   = loaded.get(key, 0)
    if ts_ms == 0 and disk:
        p = Path(disk)
        if p.exists():
            ts_ms = int(p.stat().st_mtime * 1000)
    print(f"{key}\t{size}\t{int(ts_ms/1000)}\t{disk}")
PYEOF
}

collect_ollama() {
  command -v ollama >/dev/null 2>&1 || { warn "ollama not found — skipping ollama runtime"; return; }

  local manifest_root="${HOME}/.ollama/models/manifests"

  ollama list 2>/dev/null | awk 'NR>1' | while read -r name _id size unit _rest; do
    local size_bytes=0
    case "$unit" in
      GB) size_bytes=$(awk -v s="$size" 'BEGIN{printf "%.0f", s*1073741824}') ;;
      MB) size_bytes=$(awk -v s="$size" 'BEGIN{printf "%.0f", s*1048576}') ;;
    esac
    local tag="${name##*:}" ns="${name%%:*}"
    local mpath
    mpath=$(find "$manifest_root" -name "$tag" -path "*/${ns}/*" 2>/dev/null | head -1 || true)
    local last_used_s=0
    [ -n "$mpath" ] && last_used_s=$(path_mtime "$mpath")
    echo "ollama	$name	$size_bytes	$last_used_s	$name"
  done
}

collect_mlx() {
  local models_file="${HERE}/models-mlx.txt"
  [ -f "$models_file" ] || { warn "models-mlx.txt not found — skipping mlx runtime"; return; }

  while IFS= read -r model; do
    local dir
    if [[ "$model" == /* ]]; then
      dir="$model"
    else
      # HuggingFace id: mlx-community/Foo → ~/.cache/huggingface/hub/models--mlx-community--Foo
      dir="${HF_CACHE}/models--${model//\//--}"
    fi

    local size_bytes=0 last_used_s=0
    if [ -d "$dir" ]; then
      size_bytes=$(dir_bytes "$dir")
      last_used_s=$(path_mtime "$dir")
    fi
    echo "mlx	$model	$size_bytes	$last_used_s	$dir"
  done < <(read_list "$models_file")
}

# ── gather all entries ────────────────────────────────────────────────────────
# TSV: runtime  model_id  size_bytes  last_used_s  delete_target

gather_entries() {
  case "$RUNTIME" in
    lms)    collect_lms ;;
    ollama) collect_ollama ;;
    mlx)    collect_mlx ;;
    all)    collect_lms; collect_ollama; collect_mlx ;;
  esac
}

entries_tsv=$(gather_entries)

if [[ -z "$entries_tsv" ]]; then
  echo "No models found."
  exit 0
fi

# ── display table ─────────────────────────────────────────────────────────────

print_table() {
  printf "${BOLD}%-8s  %-7s  %-10s  %s${RESET}\n" "Runtime" "Size" "Last used" "Model"
  printf '%0.s─' {1..80}; echo
  while IFS=$'\t' read -r rt id size last_used_s _target; do
    local size_str last_str
    size_str=$(fmt_bytes "$size")
    last_str=$(fmt_age_s "$last_used_s")
    printf "%-8s  %-7s  %-10s  %s\n" "[$rt]" "$size_str" "$last_str" "$id"
  done <<< "$entries_tsv"
}

# ── interactive fzf picker ────────────────────────────────────────────────────

do_interactive() {
  command -v fzf >/dev/null 2>&1 || die "fzf not installed (brew install fzf)"

  local fzf_lines=()
  while IFS=$'\t' read -r rt id size last_used_s _target; do
    local size_str last_str
    size_str=$(fmt_bytes "$size")
    last_str=$(fmt_age_s "$last_used_s")
    fzf_lines+=("$(printf "%-8s  %-7s  %-10s  %s" "[$rt]" "$size_str" "$last_str" "$id")")
  done <<< "$entries_tsv"

  local selected
  selected=$(printf '%s\n' "${fzf_lines[@]}" | \
    fzf --multi \
        --prompt='Remove > ' \
        --header='TAB = toggle  ENTER = confirm  ESC = cancel' \
        2>/dev/null || true)

  [[ -z "$selected" ]] && { echo "Nothing selected."; return; }

  # Recover TSV rows by matching model id (last field of each display line)
  local to_remove=()
  while IFS= read -r line; do
    # id is the last whitespace-delimited token after the fixed columns
    local sel_id="${line##*  }"
    sel_id="${sel_id#"${sel_id%%[![:space:]]*}"}"
    local rt row_id size ts target
    while IFS=$'\t' read -r rt row_id size ts target; do
      [[ "$row_id" == "$sel_id" ]] && to_remove+=("$rt	$row_id	$target") && break
    done <<< "$entries_tsv"
  done <<< "$selected"

  (( ${#to_remove[@]} == 0 )) && { echo "Nothing matched."; return; }

  # Align OK/FAILED column
  local max_len=0
  for entry in "${to_remove[@]}"; do
    local rt id _t
    IFS=$'\t' read -r rt id _t <<< "$entry"
    local plain="Removing [$rt] $id..."
    (( ${#plain} > max_len )) && max_len=${#plain}
  done

  for entry in "${to_remove[@]}"; do
    local rt id target
    IFS=$'\t' read -r rt id target <<< "$entry"
    local plain="Removing [$rt] $id..."
    local pad=$(( max_len - ${#plain} ))

    printf "${DIM}Removing${RESET} ${BOLD}[%s]${RESET} %s..." "$rt" "$id"

    if $DRY_RUN; then
      printf "%*s${GREEN_BOLD}dry-run${RESET}\n" $(( pad + 1 )) ""
      continue
    fi

    local ok=false
    case "$rt" in
      lms)
        if [[ -z "$target" ]]; then
          ok=false
        else
          # Unload from memory first if resident
          lms ps --json 2>/dev/null \
            | jq -e --arg k "$id" '.[] | select(.modelKey==$k)' >/dev/null 2>&1 \
            && lms unload "$id" >/dev/null 2>&1 || true
          rm -rf "$target" && ok=true
        fi
        ;;
      ollama)
        ollama rm "$target" >/dev/null 2>&1 && ok=true
        ;;
      mlx)
        [[ -d "$target" ]] && rm -rf "$target" && ok=true
        ;;
    esac

    if $ok; then
      printf "%*s${GREEN_BOLD}OK${RESET}\n" $(( pad + 1 )) ""
    else
      printf "%*s${RED_BOLD}FAILED${RESET}\n" $(( pad + 1 )) ""
    fi
  done
}

# ── main ──────────────────────────────────────────────────────────────────────

if $INTERACTIVE; then
  do_interactive
else
  $DRY_RUN && printf "${DIM}(dry-run — use --interactive to select models for removal)${RESET}\n\n"
  print_table
  echo
  total=$(echo "$entries_tsv" | wc -l | tr -d ' ')
  total_bytes=$(echo "$entries_tsv" | awk -F'\t' '{sum+=$3} END{print sum+0}')
  printf "${DIM}%d models, %s total${RESET}\n" "$total" "$(fmt_bytes "$total_bytes")"
fi
