#!/usr/bin/env bash
# bin/bench — run the matrix of (adapter x model x case), grade, and score.
#
# Each run: copy the case workdir into an isolated sandbox, hand the task to a
# CLI adapter pointed at LM Studio, then run the case's hidden grader and record
# pass/total. Results land in results/<timestamp>/results.csv plus per-run logs.
#
# Flags:
#   --adapter/-a a,b   CLI adapters to run  (default: $DEFAULT_ADAPTERS)
#   --models/--model/-m a,b  model ids            (default: models.txt)
#   --cases    a,b     case ids                   (default: all cases/)
#   --difficulty t,t   keep only cases of these tiers (easy|medium|hard) from
#                      meta.json — gates small/weak models to easier tiers; hard
#                      (multi-file, self-verify) is reserved. See TESTING-STRATEGY.md
#   --timeout  N       per-trial HARD ceiling, seconds (default: 300)
#   --warmup   N       first-byte budget, seconds (default: 180; 0 disables the
#                      whole watchdog). Time allowed from trial start until the
#                      FIRST progress artifact appears — covers a big model's
#                      load (on JIT runtimes) + prompt ingest + first turn. Make
#                      this generous for 70B+; it should exceed the slowest cold
#                      first-token you expect.
#   --stall    N       no-progress watchdog, seconds (default: 120; 0 disables).
#                      Once the first artifact has appeared, abort if no further
#                      progress artifact advances for N seconds — a file write in
#                      the sandbox, a pi/caveman transcript turn, or growth of the
#                      adapter's .bench.log. Tighter than --warmup because by now
#                      the model is known to be productive.
#                      Both are distinct from --timeout (the hard ceiling): they
#                      catch models that hang or loop without emitting the
#                      deliverable instead of burning the full ceiling. Aborted
#                      trials get status=stall; on lms the abort is tagged
#                      generating (rambling/looping) vs idle (hung), and the log
#                      records which phase fired (warmup vs stall).
#   --trials   N       repeat each (adapter,model,case) N times; results.csv records
#                      the MEDIAN score & seconds (run-to-run variance is material,
#                      so a single trial is untrustworthy). default: 1
#   --resume [RUN_ID]  resume a previous run; skip already-completed cases.
#                      RUN_ID defaults to the most recent run if omitted.
#   --list             print the resolved axes and exit
#   --interactive/-i   fzf pickers for model and adapter; skips a picker if that
#                      flag was already given (e.g. --adapter hermes -i only picks model)
#   --verbose/-v       on every non-pass trial, print the .bench.log path plus a
#                      short error excerpt inline (so failures are diagnosable
#                      without hunting through results/<ts>/sandbox/)
#   --runtime RUNTIME  inference backend: lms (default), ollama, mlx
#                      lms:    LM Studio at $LMS_BASE_URL; loads/unloads models
#                      ollama: Ollama at localhost:11434/v1; models always ready
#                      mlx:    mlx_lm.server at localhost:8080/v1; start manually
#                      Per-runtime models file used when --models not given:
#                        lms    → models.txt
#                        ollama → models-ollama.txt
#                        mlx    → models-mlx.txt
#                      Adapters: if adapters/<name>-<runtime>.sh exists it is
#                      preferred over adapters/<name>.sh for that runtime.
#   --skip-compat-filter  don't filter out adapters marked as broken in compat.json
#                      (used by bin/smoke --retry-broken to test broken adapters)
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"; source "$HERE/lib/common.sh"; source "$HERE/lib/versions.sh"

trap 'echo; warn "Interrupted — exiting"; exit 130' INT TERM
trap '' PIPE  # don't die when stdout pipe breaks (e.g. bin/bench | tee)

# ── Model aliases: cross-runtime short names ──────────────────────────────────
# models-aliases.conf: tab-separated  alias  lms_id  mlx_id  ollama_id
# Pass --model <alias> and bench resolves to the right runtime id automatically.
declare -A _ALIAS_MAP
_ALIASES_FILE="$HERE/models-aliases.conf"
if [ -f "$_ALIASES_FILE" ]; then
  while IFS=$'\t' read -r _al _lms _mlx _oll; do
    [[ "$_al" =~ ^[[:space:]]*# || -z "${_al// /}" ]] && continue
    _ALIAS_MAP["${_al}:lms"]="$_lms"
    _ALIAS_MAP["${_al}:mlx"]="$_mlx"
    _ALIAS_MAP["${_al}:ollama"]="$_oll"
  done < "$_ALIASES_FILE"
fi
# Returns the runtime-specific id for a name, or the name itself if not an alias.
# Returns empty string when alias exists but maps to "-" for this runtime.
resolve_model() {
  local name="$1" rt="$2" key rid
  key="${name}:${rt}"
  if [[ -v "_ALIAS_MAP[$key]" ]]; then
    rid="${_ALIAS_MAP[$key]}"
    [ "$rid" = "-" ] && echo "" || echo "$rid"
  else
    echo "$name"
  fi
}

# Pre-scan for --runtime so --help can show the right models file.
_help_runtime="lms"; _prev_ha=""
for _ha in "$@"; do [ "$_prev_ha" = "--runtime" ] && _help_runtime="$_ha"; _prev_ha="$_ha"; done

show_help() {
  local runtime="$1"
  awk 'NR>1 && /^[^#]/{exit} NR>1{print}' "$0"
  echo
  echo "Available adapters:"
  ls "$ADAPTERS_DIR"/*.sh 2>/dev/null \
    | xargs -I{} basename {} .sh \
    | sed "s/-${runtime}$//" \
    | sort -u \
    | awk -F- '{
        key=$1
        if (key in grp) grp[key]=grp[key]" "$0
        else { ord[++n]=key; grp[key]=$0 }
      }
      END { for(i=1;i<=n;i++) print "  "grp[ord[i]] }'
  echo
  local mfile
  case "$runtime" in
    lms)    mfile="$MODELS_FILE";;
    ollama) mfile="$HERE/models-ollama.txt";;
    mlx)    mfile="$HERE/models-mlx.txt";;
    *)      mfile="$MODELS_FILE";;
  esac
  echo "Available models ($runtime → $(basename "$mfile")):"
  read_list "$mfile" | sed 's/^/  /'
}

ADAPTERS=""; MODELS=""; CASES=""; DIFFICULTY=""; TIMEOUT=300; WARMUP=180; STALL=120; TRIALS=1; LIST=0; INTERACTIVE=0; VERBOSE=0; RUNTIME="lms"; RESUME=""; SKIP_COMPAT_FILTER=0
while [ $# -gt 0 ]; do
  case "$1" in
    --adapter|-a)        ADAPTERS="$2"; shift 2;;
    --models|--model|-m) MODELS="$2";   shift 2;;
    --cases)             CASES="$2";    shift 2;;
    --difficulty)        DIFFICULTY="$2"; shift 2;;
    --timeout)           TIMEOUT="$2";  shift 2;;
    --warmup)            WARMUP="$2";   shift 2;;
    --stall)             STALL="$2";    shift 2;;
    --trials)            TRIALS="$2";   shift 2;;
    --runtime)           RUNTIME="$2";  shift 2;;
    --list)              LIST=1; shift;;
    --interactive|-i)    INTERACTIVE=1; shift;;
    --verbose|-v)        VERBOSE=1; shift;;
    --skip-compat-filter) SKIP_COMPAT_FILTER=1; shift;;
    --resume)
      if [[ "${2:-}" =~ ^[0-9]{8}-[0-9]{6}$ ]]; then RESUME="$2"; shift 2
      else RESUME="latest"; shift; fi;;
    -h|--help)  show_help "$_help_runtime"; exit 0;;
    *) die "unknown option: $1";;
  esac
done

if [ "$INTERACTIVE" = 1 ]; then
  command -v fzf >/dev/null 2>&1 || die "fzf not installed (brew install fzf)"

  if [ -z "$MODELS" ]; then
    case "$RUNTIME" in
      lms)
        all_models="$(lms ls 2>/dev/null | awk '$1 ~ /\// {print $1}')"
        [ -z "$all_models" ] && die "no models found via lms ls"
        ;;
      ollama)
        all_models="$(read_list "$HERE/models-ollama.txt")"
        [ -z "$all_models" ] && die "no models found in models-ollama.txt"
        ;;
      mlx)
        all_models="$(read_list "$HERE/models-mlx.txt")"
        [ -z "$all_models" ] && die "no models found in models-mlx.txt"
        ;;
    esac
    sel_models="$(printf '%s\n' "$all_models" | fzf --multi --prompt='Models > ' --header='TAB = multi-select  ENTER = confirm')"
    [ -z "$sel_models" ] && die "no models selected"
    MODELS="$(printf '%s\n' "$sel_models" | paste -sd',' -)"
  fi

  if [ -z "$ADAPTERS" ]; then
    all_tools="$(ls "$ADAPTERS_DIR"/*.sh 2>/dev/null | xargs -I{} basename {} .sh | sed -E 's/-(lms|ollama|mlx)$//' | sort -u)"
    [ -z "$all_tools" ] && die "no adapters found in $ADAPTERS_DIR"
    sel_tools="$(printf '%s\n' "$all_tools" | fzf --multi --prompt='Tools  > ' --header='TAB = multi-select  ENTER = confirm')"
    [ -z "$sel_tools" ] && die "no tools selected"
    ADAPTERS="$(printf '%s\n' "$sel_tools" | paste -sd',' -)"
  fi

  echo "${C_DIM}Rerun: bin/bench --runtime $RUNTIME --adapter $ADAPTERS --model $MODELS${C_RST}"
fi

[ -z "$ADAPTERS" ] && ADAPTERS="$DEFAULT_ADAPTERS"

# Warn about slow/weak agents if selected
_slow_agents="pi|opencode|codex|interpreter|copilot"
_weak_agents="copilot|caveman|hermes|interpreter|claude"
if echo "$ADAPTERS" | grep -qE "$(echo $_slow_agents | tr '|' ' ')"; then
  warn "Selected slow agents (pi/opencode/codex/interpreter/copilot). Expect 100-500s per case. See docs/AGENT-SELECTION.md"
fi
if echo "$ADAPTERS" | grep -qE "$(echo $_weak_agents | tr '|' ' ')"; then
  warn "Selected lower-performing agents. See docs/AGENT-SELECTION.md for recommendations."
fi

[[ "$TRIALS" =~ ^[1-9][0-9]*$ ]] || die "--trials must be a positive integer (got: $TRIALS)"
[[ "$STALL" =~ ^[0-9]+$ ]]  || die "--stall must be a non-negative integer seconds (got: $STALL)"
[[ "$WARMUP" =~ ^[0-9]+$ ]] || die "--warmup must be a non-negative integer seconds (got: $WARMUP)"
# --warmup is the master switch: 0 disables the whole watchdog (warmup + stall).
[ "$WARMUP" -eq 0 ] && STALL=0
if [ "$WARMUP" -gt 0 ] && [ "$WARMUP" -ge "$TIMEOUT" ]; then
  warn "--warmup ($WARMUP) >= --timeout ($TIMEOUT): the first-byte watchdog can never fire before the hard ceiling"
fi
if [ "$STALL" -gt 0 ] && [ "$STALL" -ge "$TIMEOUT" ]; then
  warn "--stall ($STALL) >= --timeout ($TIMEOUT): the no-progress watchdog can never fire before the hard ceiling"
fi

# ── Runtime: set base URL, API key, and default models file ──────────────────
case "$RUNTIME" in
  lms)    RUNTIME_MODELS_FILE="$MODELS_FILE"
          RUNTIME_BASE_URL="$LMS_BASE_URL"
          RUNTIME_API_KEY="$LMS_API_KEY";;
  ollama) RUNTIME_MODELS_FILE="$HERE/models-ollama.txt"
          RUNTIME_BASE_URL="http://localhost:11434/v1"
          RUNTIME_API_KEY="ollama";;
  mlx)    RUNTIME_MODELS_FILE="$HERE/models-mlx.txt"
          RUNTIME_BASE_URL="http://localhost:8080/v1"
          RUNTIME_API_KEY="not-needed";;
  *)      die "unknown --runtime: $RUNTIME (valid: lms, ollama, mlx)";;
esac
export LMS_BASE_URL="$RUNTIME_BASE_URL"
export LMS_API_KEY="$RUNTIME_API_KEY"

# Resolve the three axes into arrays.
IFS=',' read -ra ADAPTER_ARR <<< "$ADAPTERS"
if [ -n "$MODELS" ]; then IFS=',' read -ra MODEL_ARR <<< "$MODELS";
else mapfile -t MODEL_ARR < <(read_list "$RUNTIME_MODELS_FILE"); fi
if [ -n "$CASES" ]; then IFS=',' read -ra CASE_ARR <<< "$CASES";
else mapfile -t CASE_ARR < <(for d in "$CASES_DIR"/*/; do [ -f "$d/meta.json" ] && basename "$d"; done); fi

# Filter out adapters marked as broken in compat.json for the first resolved model
# and current runtime. This prevents wasting time on known-incompatible adapters.
# (Skip this when --skip-compat-filter is used, e.g. by bin/smoke --retry-broken)
if [ "$SKIP_COMPAT_FILTER" = 0 ] && [ ${#MODEL_ARR[@]} -gt 0 ]; then
  _first_model="${MODEL_ARR[0]}"
  _filtered="$(filter_broken_adapters "$(IFS=','; printf '%s' "${ADAPTER_ARR[*]}")" "$_first_model" "$RUNTIME")"
  if [ -n "$_filtered" ]; then
    warn_filtered_adapters "$(IFS=','; printf '%s' "${ADAPTER_ARR[*]}")" "$_filtered" "$_first_model" "$RUNTIME"
    IFS=',' read -ra ADAPTER_ARR <<< "$_filtered"
  fi
  [ ${#ADAPTER_ARR[@]} -gt 0 ] || die "no adapters available (all filtered due to incompatibilities)"
fi

# --difficulty easy,medium → keep only cases whose meta.json difficulty matches.
# The funnel gates small/weak models to easy/medium and reserves hard (multi-file,
# self-verify) for models that have earned it. See docs/TESTING-STRATEGY.md.
if [ -n "$DIFFICULTY" ]; then
  _filtered=()
  for _c in "${CASE_ARR[@]}"; do
    _d="$(sed -nE 's/.*"difficulty"[[:space:]]*:[[:space:]]*"([a-z]+)".*/\1/p' "$CASES_DIR/$_c/meta.json" 2>/dev/null)"
    case ",$DIFFICULTY," in *",${_d:-unknown},"*) _filtered+=("$_c");; esac
  done
  CASE_ARR=("${_filtered[@]}")
  [ "${#CASE_ARR[@]}" -gt 0 ] || die "no cases match --difficulty $DIFFICULTY"
fi

if [ "$LIST" = 1 ]; then
  echo "runtime:  $RUNTIME"; echo "adapters: ${ADAPTER_ARR[*]}"; echo "models:   ${MODEL_ARR[*]}"; echo "cases:    ${CASE_ARR[*]}"; exit 0
fi

# Health check — lms has lms_up; other runtimes probe /v1/models directly.
if [ "$RUNTIME" = lms ]; then
  lms_up || die "LM Studio not reachable at $LMS_BASE_URL (run: lms server start)"
else
  # Just verify the port is accepting HTTP — any response (even 404/405) means up.
  _rt_port="$(echo "$RUNTIME_BASE_URL" | grep -oE ':[0-9]+' | tr -d ':')"
  curl -s --max-time 5 -o /dev/null "http://localhost:${_rt_port:-8080}/" 2>/dev/null \
  || die "$RUNTIME server not reachable at $RUNTIME_BASE_URL"
fi

# ── Pre-flight: check model availability ─────────────────────────────────────
# For runtimes where we can enumerate installed models, warn about missing ones
# up front so the user sees the full list before any trial runs.
preflight_check_models() {
  local runtime="$1"; shift; local models=("$@")
  local available missing=()

  case "$runtime" in
    lms)
      available="$(lms ls 2>/dev/null | awk '$1 ~ /\// {print $1}')"
      for m in "${models[@]}"; do
        printf '%s\n' "$available" | grep -qx "$m" || missing+=("$m")
      done
      [ "${#missing[@]}" -eq 0 ] && return 0
      warn "models not found in LM Studio (lms ls):"
      for m in "${missing[@]}"; do echo "    ${C_DIM}$m${C_RST}"; done
      echo "  ${C_DIM}To add: download via LM Studio or lms pull <id>${C_RST}"
      ;;
    ollama)
      available="$(ollama list 2>/dev/null | awk 'NR>1 {print $1}' | sed 's/:latest$//')"
      for m in "${models[@]}"; do
        printf '%s\n' "$available" | grep -qx "${m%:latest}" || missing+=("$m")
      done
      [ "${#missing[@]}" -eq 0 ] && return 0
      warn "models not found in Ollama:"
      for m in "${missing[@]}"; do echo "    ${C_DIM}$m${C_RST}"; done
      echo "  ${C_DIM}To fix:${C_RST}"
      for m in "${missing[@]}"; do
        if [ -f "$HERE/config-templates/${m}.Modelfile" ]; then
          echo "    ${C_DIM}bin/setup-ollama-modelfile $m${C_RST}"
        else
          echo "    ${C_DIM}ollama pull $m${C_RST}"
        fi
      done
      ;;
    mlx)
      return 0  # mlx_lm.server exposes only one model; can't enumerate
      ;;
  esac

  [ "${#missing[@]}" -eq "${#models[@]}" ] && die "no available models for runtime $runtime — nothing to run"
  echo
}

# Resolve aliases before preflight so availability checks use runtime-specific ids.
RESOLVED_MODEL_ARR=()
for _m in "${MODEL_ARR[@]}"; do
  _r="$(resolve_model "$_m" "$RUNTIME")"
  [ -n "$_r" ] && RESOLVED_MODEL_ARR+=("$_r")
done
preflight_check_models "$RUNTIME" "${RESOLVED_MODEL_ARR[@]}"

# Resolve --resume to an existing run, or start a fresh one.
declare -A _DONE=()
if [ -n "$RESUME" ]; then
  if [ "$RESUME" = "latest" ]; then
    RUN_ID="$(ls -dt "$RESULTS_DIR"/[0-9]*/ 2>/dev/null | head -1 | xargs -I{} basename {})"
    [ -z "$RUN_ID" ] && die "no previous run found to resume"
  else
    RUN_ID="$RESUME"
  fi
  RUN_DIR="$RESULTS_DIR/$RUN_ID"
  [ -d "$RUN_DIR" ] || die "run $RUN_ID not found in $RESULTS_DIR"
  CSV="$RUN_DIR/results.csv"
  [ -f "$CSV" ] || die "no results.csv in $RUN_DIR"
  while IFS=, read -r _a _m _c _rest; do
    [ "$_a" = adapter ] && continue
    _DONE["$_a,$_m,$_c"]=1
  done < "$CSV"
  info "resuming run $RUN_ID — skipping ${#_DONE[@]} already-completed cases"
else
  RUN_ID="$(date +%Y%m%d-%H%M%S)"
  RUN_DIR="$RESULTS_DIR/$RUN_ID"
  mkdir -p "$RUN_DIR"
  CSV="$RUN_DIR/results.csv"
  echo "adapter,model,case,pass,total,score,seconds,status,trials,runtime" > "$CSV"
fi
# Per-trial detail (one row per trial) kept alongside the median summary so the
# variance behind each median stays inspectable.
TRIALS_CSV="$RUN_DIR/trials.csv"
[ "$TRIALS" -gt 1 ] && [ ! -f "$TRIALS_CSV" ] && echo "adapter,model,case,trial,pass,total,score,seconds,status" > "$TRIALS_CSV"
# Per-check decomposition: one row per CHECK line a grader emits (see
# lib/grader.sh). Lets you see WHICH sub-step a model failed, not just pass/total.
CHECKS_CSV="$RUN_DIR/checks.csv"
[ ! -f "$CHECKS_CSV" ] && echo "adapter,model,case,trial,status,check" > "$CHECKS_CSV"

# Collect run configuration + system snapshot into run.json so results are
# reproducible and comparable across machines / BENCH_PARALLEL settings.
write_run_meta() {
  local out="$1"

  # CPU
  local cpu
  cpu="$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")"

  # RAM — macOS vm_stat (page-granularity)
  local page_size total_ram_bytes
  page_size="$(sysctl -n hw.pagesize 2>/dev/null || echo 16384)"
  total_ram_bytes="$(sysctl -n hw.memsize 2>/dev/null || echo 0)"

  local vm pf pa pi pw pc
  vm="$(vm_stat 2>/dev/null)"
  pf="$(awk '/^Pages free:/                    {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pa="$(awk '/^Pages active:/                  {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pi="$(awk '/^Pages inactive:/                {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pw="$(awk '/^Pages wired down:/              {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pc="$(awk '/^Pages occupied by compressor:/  {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pf="${pf:-0}"; pa="${pa:-0}"; pi="${pi:-0}"; pw="${pw:-0}"; pc="${pc:-0}"

  local ram_total_gb ram_used_gb ram_free_gb
  ram_total_gb="$(awk "BEGIN{printf \"%.1f\", $total_ram_bytes/1073741824}")"
  ram_used_gb="$( awk "BEGIN{printf \"%.1f\", ($pa+$pw+$pc)*$page_size/1073741824}")"
  ram_free_gb="$( awk "BEGIN{printf \"%.1f\", ($pf+$pi)*$page_size/1073741824}")"

  # Swap (vm.swapusage: total = 3072.00M  used = 2066.50M ...)
  local swap_line swap_total swap_used
  swap_line="$(sysctl vm.swapusage 2>/dev/null || echo "")"
  swap_total="$(grep -oE 'total = [0-9.]+[MG]' <<<"$swap_line" | grep -oE '[0-9.]+[MG]')"
  swap_used="$( grep -oE 'used = [0-9.]+[MG]'  <<<"$swap_line" | grep -oE '[0-9.]+[MG]')"
  swap_total="${swap_total:-0M}"; swap_used="${swap_used:-0M}"

  # Axes as JSON arrays
  local adapters_json models_json cases_json
  adapters_json="$(printf '"%s",' "${ADAPTER_ARR[@]}" | sed 's/,$//')"
  models_json="$(  printf '"%s",' "${MODEL_ARR[@]}"   | sed 's/,$//')"
  cases_json="$(   printf '"%s",' "${CASE_ARR[@]}"    | sed 's/,$//')"

  # Collect version information for runtime and adapters
  local run_date run_time
  run_date="$(date -d @${RUN_ID%-*} +%Y-%m-%d 2>/dev/null || date -j -f '%Y%m%d-%H%M%S' "$RUN_ID" +%Y-%m-%d)"
  run_time="$(echo "$RUN_ID" | cut -d'-' -f2 | sed 's/\(..\)/\1:/g;s/:$//')"

  # Build versions JSON
  local runtime_info runtime_name runtime_ver runtime_src
  runtime_info="$(get_runtime_version "$RUNTIME")"
  IFS=$'\t' read -r runtime_name runtime_ver runtime_src <<<"$runtime_info"

  local agents_json="{"
  local first=true
  for adapter in "${ADAPTER_ARR[@]}"; do
    local ag_info agent_name agent_ver agent_src
    ag_info="$(get_version_info "$adapter" "$RUNTIME")"
    IFS=$'\t' read -r agent_name agent_ver agent_src <<<"$ag_info"

    if [ "$first" = true ]; then
      first=false
    else
      agents_json+=","
    fi
    # Escape quotes in version strings for JSON
    agent_ver="${agent_ver//\"/\\\"}"
    agent_src="${agent_src//\"/\\\"}"
    agents_json+="\"$agent_name\":{\"version\":\"$agent_ver\",\"source\":\"$agent_src\"}"
  done
  agents_json+="}"

  cat >"$out" <<EOF
{
  "run_id": "$RUN_ID",
  "run_date": "$run_date",
  "run_time": "$run_time",
  "runtime": "$RUNTIME",
  "versions": {
    "runtime": {
      "name": "$runtime_name",
      "version": "$runtime_ver",
      "source": "$runtime_src"
    },
    "agents": $agents_json
  },
  "bench": {
    "parallel": $BENCH_PARALLEL,
    "context": $BENCH_CONTEXT,
    "ttl_minutes": $BENCH_TTL_MINUTES,
    "timeout_seconds": $TIMEOUT,
    "warmup_seconds": $WARMUP,
    "stall_seconds": $STALL,
    "trials": $TRIALS
  },
  "axes": {
    "adapters": [$adapters_json],
    "models": [$models_json],
    "cases": [$cases_json]
  },
  "system": {
    "cpu": "$cpu",
    "ram_total_gb": $ram_total_gb,
    "ram_used_gb": $ram_used_gb,
    "ram_free_gb": $ram_free_gb,
    "swap_total": "$swap_total",
    "swap_used": "$swap_used"
  }
}
EOF
}

[ ! -f "$RUN_DIR/run.json" ] && write_run_meta "$RUN_DIR/run.json"

if [ "$WARMUP" -eq 0 ]; then _wd_note="watchdog off"
else _wd_note="warmup ${WARMUP}s, stall ${STALL}s"; [ "$STALL" -eq 0 ] && _wd_note="warmup ${WARMUP}s, stall off"; fi
info "run $RUN_ID  —  ${#ADAPTER_ARR[@]} adapters x ${#MODEL_ARR[@]} models x ${#CASE_ARR[@]} cases x ${TRIALS} trial(s)  --parallel $BENCH_PARALLEL  (timeout ${TIMEOUT}s, ${_wd_note})"
echo

# pi/caveman persist a live session transcript keyed by the sandbox cwd slug
# ('/a/b' -> '--a-b--'). Each assistant turn / tool call appends a record, so the
# dir mtime is a real-time progress signal. Mirrors bin/trace-tool-calls' slug.
_pi_session_dir() {
  local sb; sb="$(cd "$1" 2>/dev/null && pwd -P)" || return 1
  printf '%s/.pi/agent/sessions/--%s--' "$HOME" "$(printf '%s' "${sb#/}" | tr '/' '-')"
}

# Newest mtime (epoch) across every progress artifact for a trial: a file write
# in the sandbox (the deliverable), a pi/caveman transcript turn, or growth of
# the adapter's stdout log. Excludes .git churn and our own probe log. Prints 0
# when nothing is found.
progress_epoch() {
  local sb="$1" best=0 m sd
  m="$(find "$sb" -type f -not -path '*/.git/*' -not -name '.lms-stream.log' \
         -exec stat -f %m {} + 2>/dev/null | sort -rn | head -1)"
  [ -n "$m" ] && [ "$m" -gt "$best" ] && best="$m"
  sd="$(_pi_session_dir "$sb")" || sd=""
  if [ -n "$sd" ] && [ -d "$sd" ]; then
    m="$(find "$sd" -type f -exec stat -f %m {} + 2>/dev/null | sort -rn | head -1)"
    [ -n "$m" ] && [ "$m" -gt "$best" ] && best="$m"
  fi
  printf '%s' "$best"
}

# Recursively signal a process and all its descendants (subshell -> timeout ->
# bash adapter -> node/pi). Plain `kill <pid>` hits only the subshell and leaves
# the model process generating; we must walk the tree.
kill_tree() {
  local p="$1" sig="${2:-TERM}" c
  for c in $(pgrep -P "$p" 2>/dev/null); do kill_tree "$c" "$sig"; done
  kill -"$sig" "$p" 2>/dev/null
}

# Run one (adapter,model,case) trial in its own sandbox; echo "pass total elapsed status".
run_trial() {
  local adapter_sh="$1" model="$2" case_src="$3" sandbox="$4"
  local logf="$sandbox/.bench.log"
  mkdir -p "$sandbox"
  cp -R "$case_src/workdir/." "$sandbox/" 2>/dev/null || true
  # Give the sandbox a self-contained git repo so adapters that rely on git
  # (e.g. aider's repo-map) discover only the case files, not the main project.
  ( cd "$sandbox" && git init -q && git add -A && git commit -q --allow-empty -m "init" ) 2>/dev/null || true

  local start status="ok" rc elapsed
  start=$(date +%s)

  # lms token probe (diagnostic): capture the server log during the trial so a
  # stall can be classified as generating (model looping/rambling) vs idle (hung
  # or crashed). Lightweight log subscription; trials never run concurrently.
  local lmslog="" lms_pid=""
  if [ "$WARMUP" -gt 0 ] && [ "$RUNTIME" = lms ] && command -v lms >/dev/null 2>&1; then
    lmslog="$sandbox/.lms-stream.log"
    ( lms log stream --stats >"$lmslog" 2>/dev/null ) & lms_pid=$!
  fi

  # Launch the adapter under the hard ceiling, backgrounded so the watchdog can
  # poll progress and abort early on a no-progress stall.
  ( cd "$sandbox" && MODEL_ID="$model" run_timeout "$TIMEOUT" \
      bash "$adapter_sh" <"$case_src/task.md" ) >"$logf" 2>&1 &
  local apid=$!

  # Two-phase watchdog (disabled when WARMUP=0):
  #   warmup phase — start until the FIRST progress artifact: allow $WARMUP secs
  #                  (big-model load on JIT runtimes + prompt ingest + first turn).
  #   stall phase  — after the first artifact: reset on each new artifact; abort
  #                  if none advances for $STALL secs (tighter — model is known
  #                  productive by now).
  # The lms probe only LABELS the abort (generating vs idle); it deliberately does
  # NOT extend the budget, so a model rambling forever in one turn is still caught.
  #
  # Early-error fast path: don't wait out the budget when a fatal adapter/runtime
  # failure is already in the log — abort within a tick. Patterns are kept tight
  # to infra/tool failures that ~never appear in healthy output (NOT a bare
  # "error", which is common in model prose). For pi, log output mid-run is
  # adapter/runtime stderr anyway (model text flushes only at the end).
  local _ERR_RE='command not found|: not found|not installed|ECONNREFUSED|[Cc]onnection refused|fetch failed|Traceback \(most recent call last\)|Cannot find module|ENOENT|out of memory|CUDA (error|out of memory)|model_not_found|HTTP error (4|5)[0-9][0-9]|panic:|FATAL'
  local last_prog="$start" first_seen=0 abort_reason="" phase budget
  while kill -0 "$apid" 2>/dev/null; do
    sleep 2
    kill -0 "$apid" 2>/dev/null || break
    [ "$WARMUP" -gt 0 ] || continue

    # Fast path: a fatal error is already visible — abort now, don't wait.
    if grep -qaE "$_ERR_RE" "$logf" 2>/dev/null; then
      printf 'WATCHDOG: fatal error in log — aborting trial early\n' >>"$logf"
      abort_reason="error"
      kill_tree "$apid" TERM; ( sleep 5; kill_tree "$apid" KILL ) &
      break
    fi

    local p; p="$(progress_epoch "$sandbox")"
    if [ -n "$p" ] && [ "$p" -gt "$last_prog" ]; then last_prog="$p"; first_seen=1; fi
    if [ "$first_seen" = 1 ]; then phase="stall"; budget="$STALL"; else phase="warmup"; budget="$WARMUP"; fi
    if [ "$budget" -gt 0 ] && [ $(( $(date +%s) - last_prog )) -ge "$budget" ]; then
      local genx="idle"
      if [ -n "$lmslog" ] && [ -f "$lmslog" ] && [ "$(wc -c <"$lmslog" 2>/dev/null || echo 0)" -gt 64 ]; then
        genx="generating"
      fi
      printf 'WATCHDOG: %s phase — no progress for %ss (lms: %s) — aborting trial\n' "$phase" "$budget" "$genx" >>"$logf"
      abort_reason="stall"
      kill_tree "$apid" TERM
      ( sleep 5; kill_tree "$apid" KILL ) &
      break
    fi
  done
  wait "$apid"; rc=$?

  [ -n "$lms_pid" ] && kill_tree "$lms_pid" TERM 2>/dev/null

  if [ -n "$abort_reason" ]; then status="$abort_reason"
  elif [ $rc -eq 124 ]; then status="timeout"
  elif [ $rc -ne 0 ]; then status="error($rc)"; fi
  elapsed=$(( $(date +%s) - start ))

  local grade_out line pass total
  grade_out="$( cd "$sandbox" && CASE_DIR="$case_src" REPO_ROOT="$HERE" \
                  bash "$case_src/check/run.sh" 2>>"$logf" )"
  line="$(printf '%s\n' "$grade_out" | grep -E '^RESULT ' | tail -1)"
  pass="$(sed -nE 's/.*pass=([0-9]+).*/\1/p' <<<"$line")"; pass="${pass:-0}"
  total="$(sed -nE 's/.*total=([0-9]+).*/\1/p' <<<"$line")"; total="${total:-0}"
  # Stash any per-check CHECK lines for the caller to fold into checks.csv.
  printf '%s\n' "$grade_out" | grep -E '^CHECK (pass|fail) ' > "$sandbox/.checks" || true
  printf '%s %s %s %s\n' "$pass" "$total" "$elapsed" "$status"
}

# Append a sandbox's .checks lines to checks.csv, tagged with the combo + trial.
record_checks() {  # adapter model_alias case_id trial sandbox
  local f="$5/.checks"
  [ -f "$f" ] || return 0
  while read -r _kw st cid; do
    [ -z "$st" ] && continue
    printf '%s,%s,%s,%s,%s,%s\n' "$1" "$2" "$3" "$4" "$st" "${cid//,/;}" >> "$CHECKS_CSV"
  done < "$f"
}

# Unload all running instances of a model by their exact lms-ps identifier (e.g.
# "qwen/qwen3-coder-30b:2"). lms unload by base name silently misses variant-
# qualified instances, which is why models can survive across bench runs.
lms_unload_model() {
  local model="$1"
  local ids
  ids="$(lms ps --json 2>/dev/null | jq -r --arg m "$model" '.[] | select(.modelKey==$m) | .identifier')"
  [ -z "$ids" ] && return 0
  while IFS= read -r id; do
    info "unloading model: $model ($id)"
    lms unload "$id"
  done <<< "$ids"
}

info "runtime: $RUNTIME  base_url: $RUNTIME_BASE_URL"


for model_alias in "${MODEL_ARR[@]}"; do
  # Resolve alias → runtime-specific id. model_alias used in CSV/display; model
  # is the id passed to the runtime (they differ when an alias is used).
  model="$(resolve_model "$model_alias" "$RUNTIME")"
  if [ -z "$model" ]; then
    warn "model '$model_alias' not mapped for runtime $RUNTIME (alias maps to '-') — skipping"
    continue
  fi

  if [ "$RUNTIME" = lms ]; then
    # Clear any stale instances before loading (":2" variants survive across runs).
    lms_unload_model "$model"
    [ "$model" != "$model_alias" ] && _id_note=" ($model)" || _id_note=""
    info "loading model: $model_alias${_id_note}"
    bench_ttl_secs=$(( BENCH_TTL_MINUTES * 60 ))
    lms load --yes --ttl="$bench_ttl_secs" --context-length "$BENCH_CONTEXT" --parallel "$BENCH_PARALLEL" "$model"
    _lms_rc=$?
    if [ $_lms_rc -eq 130 ] || [ $_lms_rc -eq 143 ]; then exit $_lms_rc; fi
    if [ $_lms_rc -ne 0 ]; then warn "lms load failed for $model — skipping"; continue; fi
  elif [ "$RUNTIME" = ollama ]; then
    if ! ollama list 2>/dev/null | awk 'NR>1{print $1}' | sed 's/:latest$//' | grep -qx "${model%:latest}"; then
      if [ -f "$HERE/config-templates/${model}.Modelfile" ]; then
        warn "model not found in ollama: $model  (run: bin/setup-ollama-modelfile $model) — skipping"
      else
        warn "model not found in ollama: $model  (run: ollama pull $model) — skipping"
      fi
      continue
    fi
    info "model: $model_alias  (ollama manages loading)"
  else
    info "model: $model_alias  (${RUNTIME} manages loading)"
  fi

  for adapter in "${ADAPTER_ARR[@]}"; do
    # Prefer a runtime-specific adapter (e.g. hermes-ollama.sh) if one exists.
    adapter_sh="$ADAPTERS_DIR/$adapter-$RUNTIME.sh"
    [ -f "$adapter_sh" ] || adapter_sh="$ADAPTERS_DIR/$adapter.sh"
    [ -f "$adapter_sh" ] || { warn "no adapter $adapter.sh — skipping"; continue; }
    command -v "$adapter" >/dev/null 2>&1 || { warn "$adapter not installed — skipping"; continue; }

    # For lms, confirm the model is still loaded before each adapter — it can
    # crash or be evicted between adapters (e.g. OOM on a model that was
    # marginal at load time), causing silent wrong-model responses or API 400s.
    if [ "$RUNTIME" = lms ]; then
      if ! lms ps --json 2>/dev/null | jq -e --arg m "$model" 'any(.[]; .modelKey == $m)' >/dev/null 2>&1; then
        warn "model $model no longer loaded before $adapter — skipping remaining adapters for this model"
        break
      fi
    fi

    for case_id in "${CASE_ARR[@]}"; do
      case_src="$CASES_DIR/$case_id"
      [ -f "$case_src/meta.json" ] || { warn "no case $case_id — skipping"; continue; }

      base_sandbox="$RUN_DIR/sandbox/$adapter/$(fs_safe "$model_alias")/$case_id"

      # Skip if already completed in a resumed run.
      if [ -n "${_DONE[$adapter,$model_alias,$case_id]+x}" ]; then
        echo "${C_DIM}  skip (done) $adapter | $model_alias | $case_id${C_RST}"
        continue
      fi

      # --- run N trials, collecting per-trial pass/seconds/status ----------
      scores=(); secs=(); statuses=(); total=0; n_ok=0
      for ((t=1; t<=TRIALS; t++)); do
        if [ "$TRIALS" -gt 1 ]; then sandbox="$base_sandbox/trial-$t"; else sandbox="$base_sandbox"; fi

        if [ "$VERBOSE" = 1 ]; then
          # Verbose: run SYNCHRONOUSLY so the adapter's /dev/tty output (hermes
          # writes its TUI there, bypassing stdout/stderr redirections) flows
          # directly to the terminal.  Background jobs lose /dev/tty write access
          # because they leave the terminal's foreground process group.
          [ -t 1 ] && printf '%s\n' "${C_DIM}>>> $adapter | $model_alias | $case_id${C_RST}"
          # Save cursor after the header so verbose debug lines can be folded on PASS.
          [ -t 1 ] && printf '\033[s'

          # Pre-create sandbox + log so tails start before the adapter does.
          mkdir -p "$sandbox"; touch "$sandbox/.bench.log"
          _vtail_pids=()

          # Tail the bench log (stdout/stderr from all adapters; grader output).
          # Use -F to survive the truncation when run_trial redirects >"$logf".
          ( tail -n 0 -F "$sandbox/.bench.log" 2>/dev/null \
            | sed -u "s/^/  ${C_DIM}/" ) &
          _vtail_pids+=($!)

          # For hermes: also tail agent.log filtered to high-signal lines.
          # Drops plugin registration, HTTP client lifecycle, and HTTP responses
          # (noise); keeps API-call latency, turn completions, and errors.
          _hermes_log="${HOME}/.hermes/logs/agent.log"
          if [ "$adapter" = hermes ] && [ -f "$_hermes_log" ]; then
            ( tail -n 0 -F "$_hermes_log" 2>/dev/null \
              | grep --line-buffered -v "Plugin\|OpenAI client \|primp: response" \
              | sed -u "s/^/  ${C_BLU}▸${C_RST} ${C_DIM}/" ) &
            _vtail_pids+=($!)
          fi

          read -r t_pass t_total t_elapsed t_status < \
            <(run_trial "$adapter_sh" "$model" "$case_src" "$sandbox")

          # Give buffered output a moment to flush before killing the tails.
          sleep 0.3
          for _vp in "${_vtail_pids[@]}"; do
            kill "$_vp" 2>/dev/null; wait "$_vp" 2>/dev/null
          done
          # Fold verbose debug lines when all test cases passed.
          [ -t 1 ] && [ "$t_pass" = "$t_total" ] && [ "$t_total" -gt 0 ] && printf '\033[u\033[J'
        else
          # Normal: run in background so we can animate a live timer line.
          _trial_out="$(mktemp)"
          run_trial "$adapter_sh" "$model" "$case_src" "$sandbox" > "$_trial_out" &
          _trial_pid=$!
          _t0=$(date +%s)
          if [ -t 1 ]; then
            while kill -0 "$_trial_pid" 2>/dev/null; do
              _dt=$(( $(date +%s) - _t0 ))
              printf '\r%s\033[K' "${C_DIM}[${_dt}s]${C_RST} $adapter | $model_alias | $case_id"
              sleep 1
            done
            printf '\r\033[K'  # clear timer line before printing result
          fi
          wait "$_trial_pid" 2>/dev/null
          read -r t_pass t_total t_elapsed t_status < "$_trial_out"
          rm -f "$_trial_out"
        fi

        record_checks "$adapter" "$model_alias" "$case_id" "$t" "$sandbox"

        total="$t_total"
        if [ "$t_total" -gt 0 ]; then t_score="$(awk "BEGIN{printf \"%.4f\", $t_pass/$t_total}")"; else t_score="0"; fi
        scores+=("$t_score"); secs+=("$t_elapsed"); statuses+=("$t_status")
        [ "$t_status" = ok ] && n_ok=$((n_ok+1))
        [ "$TRIALS" -gt 1 ] && \
          echo "$adapter,$model_alias,$case_id,$t,$t_pass,$t_total,$(awk "BEGIN{printf \"%.2f\", $t_score}"),$t_elapsed,$t_status" >> "$TRIALS_CSV"
      done

      # --- collapse trials into medians ------------------------------------
      score="$(awk "BEGIN{printf \"%.2f\", $(median "${scores[@]}")}")"
      elapsed="$(awk "BEGIN{printf \"%.0f\", $(median "${secs[@]}")}")"
      # pass derived from the median score so it stays an integer consistent with score.
      pass="$(awk "BEGIN{printf \"%.0f\", $score*$total}")"
      # status: single status if all trials agree, else the distinct set joined with |.
      status="$(printf '%s\n' "${statuses[@]}" | sort -u | paste -sd'|' -)"

      echo "$adapter,$model_alias,$case_id,$pass,$total,$score,$elapsed,$status,$TRIALS,$RUNTIME" >> "$CSV"

      # --- report ----------------------------------------------------------
      sec_note="${elapsed}s"; [ "$TRIALS" -gt 1 ] && sec_note="med ${elapsed}s, ${n_ok}/${TRIALS} ok"
      status_note=""; [ "$status" != "ok" ] && status_note=" $status"
      logf="$sandbox/.bench.log"

      if   [ "$pass" = "$total" ] && [ "$total" -gt 0 ]; then ok   "$adapter | $model_alias | $case_id  ->  $pass/$total  ${C_DIM}${sec_note}${C_RST}"
      elif [ "$pass" -gt 0 ]; then warn "$adapter | $model_alias | $case_id  ->  $pass/$total  ${C_DIM}${sec_note}${status_note}${C_RST}"
      else err "$adapter | $model_alias | $case_id  ->  $pass/$total  ${C_DIM}${sec_note}${status_note}${C_RST}"; fi

      # On any non-pass, point at the log and (in --verbose) show an excerpt.
      if [ "$pass" != "$total" ] || [ "$total" -eq 0 ]; then
        echo "      ${C_DIM}log: ${logf#"$HERE"/}${C_RST}"
        if [ "$VERBOSE" = 1 ] && [ -f "$logf" ]; then
          # Grader signals: MISS:/RESULT; adapter/runtime: errors, refusals.
          _err_lines="$(grep -aiE 'WATCHDOG:|MISS:|^RESULT |error|refus|not ok|failed|exception|traceback|cannot|denied|no such' "$logf" \
            | grep -av '[⠁-⣿]' | tail -20)"
          [ -n "$_err_lines" ] && printf '%s\n' "$_err_lines" | sed "s/^/        ${C_DIM}| /; s/$/${C_RST}/"
          _log_lines="$(wc -l < "$logf" | tr -d ' ')"
          if [ "${_log_lines:-0}" -gt 0 ]; then
            echo "      ${C_DIM}--- last lines of log ---${C_RST}"
            tail -8 "$logf" | grep -av '[⠁-⣿]' | sed "s/^/        ${C_DIM}| /; s/$/${C_RST}/"
          fi
        fi
      fi
    done
  done

  case "$RUNTIME" in
    lms)    lms_unload_model "$model";;
    ollama) info "unloading model: $model_alias"; ollama stop "$model" 2>/dev/null || true;;
    mlx)    ;;  # mlx_lm.server serves one model for its lifetime; restart to change models
  esac
done

echo
info "results: $CSV"
"$HERE/bin/report" "$CSV"
