#!/usr/bin/env bash
# bin/bench — run the matrix of (adapter x model x case), grade, and score.
#
# Each run: copy the case workdir into an isolated sandbox, hand the task to a
# CLI adapter pointed at LM Studio, then run the case's hidden grader and record
# pass/total. Results land in results/<timestamp>/results.csv plus per-run logs.
#
# Flags:
#   --tool/-t a,b      CLI tools/adapters to run  (default: $DEFAULT_ADAPTERS)
#   --models/--model/-m a,b  model ids            (default: models.txt)
#   --cases    a,b     case ids                   (default: all cases/)
#   --timeout  N       per-trial timeout, seconds (default: 300)
#   --trials   N       repeat each (tool,model,case) N times; results.csv records
#                      the MEDIAN score & seconds (run-to-run variance is material,
#                      so a single trial is untrustworthy). default: 1
#   --list             print the resolved axes and exit
#   --interactive/-i   fzf pickers for model and tool; skips a picker if that
#                      flag was already given (e.g. --tool hermes -i only picks model)
#   --verbose/-v       on every non-pass trial, print the .bench.log path plus a
#                      short error excerpt inline (so failures are diagnosable
#                      without hunting through results/<ts>/sandbox/)
#   --runtime RUNTIME  inference backend: lms (default), ollama, mlx
#                      lms:    LM Studio at $LMS_BASE_URL; loads/unloads models
#                      ollama: Ollama at localhost:11434/v1; models always ready
#                      mlx:    mlx_lm.server at localhost:8080/v1; start manually
#                      Per-runtime models file used when --models not given:
#                        lms    → models.txt
#                        ollama → models-ollama.txt
#                        mlx    → models-mlx.txt
#                      Adapters: if adapters/<name>-<runtime>.sh exists it is
#                      preferred over adapters/<name>.sh for that runtime.
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"; source "$HERE/lib/common.sh"

trap 'echo; warn "Interrupted — exiting"; exit 130' INT TERM

ADAPTERS=""; MODELS=""; CASES=""; TIMEOUT=300; TRIALS=1; LIST=0; INTERACTIVE=0; VERBOSE=0; RUNTIME="lms"
while [ $# -gt 0 ]; do
  case "$1" in
    --tool|-t)           ADAPTERS="$2"; shift 2;;
    --models|--model|-m) MODELS="$2";   shift 2;;
    --cases)             CASES="$2";    shift 2;;
    --timeout)           TIMEOUT="$2";  shift 2;;
    --trials)            TRIALS="$2";   shift 2;;
    --runtime)           RUNTIME="$2";  shift 2;;
    --list)              LIST=1; shift;;
    --interactive|-i)    INTERACTIVE=1; shift;;
    --verbose|-v)        VERBOSE=1; shift;;
    -h|--help)  sed -n '2,30p' "$0"; exit 0;;
    *) die "unknown option: $1";;
  esac
done

if [ "$INTERACTIVE" = 1 ]; then
  command -v fzf >/dev/null 2>&1 || die "fzf not installed (brew install fzf)"

  if [ -z "$MODELS" ]; then
    all_models="$(lms ls 2>/dev/null | awk '$1 ~ /\// {print $1}')"
    [ -z "$all_models" ] && die "no models found via lms ls"
    sel_models="$(printf '%s\n' "$all_models" | fzf --multi --prompt='Models > ' --header='TAB = multi-select  ENTER = confirm')"
    [ -z "$sel_models" ] && die "no models selected"
    MODELS="$(printf '%s\n' "$sel_models" | paste -sd',' -)"
  fi

  if [ -z "$ADAPTERS" ]; then
    all_tools="$(ls "$ADAPTERS_DIR"/*.sh 2>/dev/null | xargs -I{} basename {} .sh | sort)"
    [ -z "$all_tools" ] && die "no adapters found in $ADAPTERS_DIR"
    sel_tools="$(printf '%s\n' "$all_tools" | fzf --multi --prompt='Tools  > ' --header='TAB = multi-select  ENTER = confirm')"
    [ -z "$sel_tools" ] && die "no tools selected"
    ADAPTERS="$(printf '%s\n' "$sel_tools" | paste -sd',' -)"
  fi
fi

[ -z "$ADAPTERS" ] && ADAPTERS="$DEFAULT_ADAPTERS"
[[ "$TRIALS" =~ ^[1-9][0-9]*$ ]] || die "--trials must be a positive integer (got: $TRIALS)"

# ── Runtime: set base URL, API key, and default models file ──────────────────
case "$RUNTIME" in
  lms)    RUNTIME_MODELS_FILE="$MODELS_FILE"
          RUNTIME_BASE_URL="$LMS_BASE_URL"
          RUNTIME_API_KEY="$LMS_API_KEY";;
  ollama) RUNTIME_MODELS_FILE="$HERE/models-ollama.txt"
          RUNTIME_BASE_URL="http://localhost:11434/v1"
          RUNTIME_API_KEY="ollama";;
  mlx)    RUNTIME_MODELS_FILE="$HERE/models-mlx.txt"
          RUNTIME_BASE_URL="http://localhost:8080/v1"
          RUNTIME_API_KEY="not-needed";;
  *)      die "unknown --runtime: $RUNTIME (valid: lms, ollama, mlx)";;
esac
export LMS_BASE_URL="$RUNTIME_BASE_URL"
export LMS_API_KEY="$RUNTIME_API_KEY"

# Resolve the three axes into arrays.
IFS=',' read -ra ADAPTER_ARR <<< "$ADAPTERS"
if [ -n "$MODELS" ]; then IFS=',' read -ra MODEL_ARR <<< "$MODELS";
else mapfile -t MODEL_ARR < <(read_list "$RUNTIME_MODELS_FILE"); fi
if [ -n "$CASES" ]; then IFS=',' read -ra CASE_ARR <<< "$CASES";
else mapfile -t CASE_ARR < <(for d in "$CASES_DIR"/*/; do [ -f "$d/meta.json" ] && basename "$d"; done); fi

if [ "$LIST" = 1 ]; then
  echo "runtime:  $RUNTIME"; echo "adapters: ${ADAPTER_ARR[*]}"; echo "models:   ${MODEL_ARR[*]}"; echo "cases:    ${CASE_ARR[*]}"; exit 0
fi

# Health check — lms has lms_up; other runtimes probe /v1/models directly.
if [ "$RUNTIME" = lms ]; then
  lms_up || die "LM Studio not reachable at $LMS_BASE_URL (run: lms server start)"
else
  # Just verify the port is accepting HTTP — any response (even 404/405) means up.
  _rt_port="$(echo "$RUNTIME_BASE_URL" | grep -oE ':[0-9]+' | tr -d ':')"
  curl -s --max-time 5 -o /dev/null "http://localhost:${_rt_port:-8080}/" 2>/dev/null \
  || die "$RUNTIME server not reachable at $RUNTIME_BASE_URL"
fi

RUN_ID="$(date +%Y%m%d-%H%M%S)"
RUN_DIR="$RESULTS_DIR/$RUN_ID"
mkdir -p "$RUN_DIR"
CSV="$RUN_DIR/results.csv"
echo "adapter,model,case,pass,total,score,seconds,status,trials,runtime" > "$CSV"
# Per-trial detail (one row per trial) kept alongside the median summary so the
# variance behind each median stays inspectable.
TRIALS_CSV="$RUN_DIR/trials.csv"
[ "$TRIALS" -gt 1 ] && echo "adapter,model,case,trial,pass,total,score,seconds,status" > "$TRIALS_CSV"

# Collect run configuration + system snapshot into run.json so results are
# reproducible and comparable across machines / BENCH_PARALLEL settings.
write_run_meta() {
  local out="$1"

  # CPU
  local cpu
  cpu="$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")"

  # RAM — macOS vm_stat (page-granularity)
  local page_size total_ram_bytes
  page_size="$(sysctl -n hw.pagesize 2>/dev/null || echo 16384)"
  total_ram_bytes="$(sysctl -n hw.memsize 2>/dev/null || echo 0)"

  local vm pf pa pi pw pc
  vm="$(vm_stat 2>/dev/null)"
  pf="$(awk '/^Pages free:/                    {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pa="$(awk '/^Pages active:/                  {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pi="$(awk '/^Pages inactive:/                {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pw="$(awk '/^Pages wired down:/              {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pc="$(awk '/^Pages occupied by compressor:/  {gsub(/\./,"",$NF); print $NF+0}' <<<"$vm")"
  pf="${pf:-0}"; pa="${pa:-0}"; pi="${pi:-0}"; pw="${pw:-0}"; pc="${pc:-0}"

  local ram_total_gb ram_used_gb ram_free_gb
  ram_total_gb="$(awk "BEGIN{printf \"%.1f\", $total_ram_bytes/1073741824}")"
  ram_used_gb="$( awk "BEGIN{printf \"%.1f\", ($pa+$pw+$pc)*$page_size/1073741824}")"
  ram_free_gb="$( awk "BEGIN{printf \"%.1f\", ($pf+$pi)*$page_size/1073741824}")"

  # Swap (vm.swapusage: total = 3072.00M  used = 2066.50M ...)
  local swap_line swap_total swap_used
  swap_line="$(sysctl vm.swapusage 2>/dev/null || echo "")"
  swap_total="$(grep -oE 'total = [0-9.]+[MG]' <<<"$swap_line" | grep -oE '[0-9.]+[MG]')"
  swap_used="$( grep -oE 'used = [0-9.]+[MG]'  <<<"$swap_line" | grep -oE '[0-9.]+[MG]')"
  swap_total="${swap_total:-0M}"; swap_used="${swap_used:-0M}"

  # Axes as JSON arrays
  local adapters_json models_json cases_json
  adapters_json="$(printf '"%s",' "${ADAPTER_ARR[@]}" | sed 's/,$//')"
  models_json="$(  printf '"%s",' "${MODEL_ARR[@]}"   | sed 's/,$//')"
  cases_json="$(   printf '"%s",' "${CASE_ARR[@]}"    | sed 's/,$//')"

  cat >"$out" <<EOF
{
  "run_id": "$RUN_ID",
  "runtime": "$RUNTIME",
  "bench": {
    "parallel": $BENCH_PARALLEL,
    "context": $BENCH_CONTEXT,
    "ttl_minutes": $BENCH_TTL_MINUTES,
    "timeout_seconds": $TIMEOUT,
    "trials": $TRIALS
  },
  "axes": {
    "adapters": [$adapters_json],
    "models": [$models_json],
    "cases": [$cases_json]
  },
  "system": {
    "cpu": "$cpu",
    "ram_total_gb": $ram_total_gb,
    "ram_used_gb": $ram_used_gb,
    "ram_free_gb": $ram_free_gb,
    "swap_total": "$swap_total",
    "swap_used": "$swap_used"
  }
}
EOF
}

write_run_meta "$RUN_DIR/run.json"

info "run $RUN_ID  —  ${#ADAPTER_ARR[@]} adapters x ${#MODEL_ARR[@]} models x ${#CASE_ARR[@]} cases x ${TRIALS} trial(s)  --parallel $BENCH_PARALLEL"
echo

# Run one (adapter,model,case) trial in its own sandbox; echo "pass total elapsed status".
run_trial() {
  local adapter_sh="$1" model="$2" case_src="$3" sandbox="$4"
  local logf="$sandbox/.bench.log"
  mkdir -p "$sandbox"
  cp -R "$case_src/workdir/." "$sandbox/" 2>/dev/null || true

  local start status="ok" rc elapsed
  start=$(date +%s)
  ( cd "$sandbox" && MODEL_ID="$model" run_timeout "$TIMEOUT" \
      bash "$adapter_sh" <"$case_src/task.md" ) >"$logf" 2>&1
  rc=$?
  [ $rc -eq 124 ] && status="timeout"
  [ $rc -ne 0 ] && [ $rc -ne 124 ] && status="error($rc)"
  elapsed=$(( $(date +%s) - start ))

  local grade_out line pass total
  grade_out="$( cd "$sandbox" && CASE_DIR="$case_src" REPO_ROOT="$HERE" \
                  bash "$case_src/check/run.sh" 2>>"$logf" )"
  line="$(printf '%s\n' "$grade_out" | grep -E '^RESULT ' | tail -1)"
  pass="$(sed -nE 's/.*pass=([0-9]+).*/\1/p' <<<"$line")"; pass="${pass:-0}"
  total="$(sed -nE 's/.*total=([0-9]+).*/\1/p' <<<"$line")"; total="${total:-0}"
  printf '%s %s %s %s\n' "$pass" "$total" "$elapsed" "$status"
}

# Unload all running instances of a model by their exact lms-ps identifier (e.g.
# "qwen/qwen3-coder-30b:2"). lms unload by base name silently misses variant-
# qualified instances, which is why models can survive across bench runs.
lms_unload_model() {
  local model="$1"
  local ids
  ids="$(lms ps --json 2>/dev/null | jq -r --arg m "$model" '.[] | select(.modelKey==$m) | .identifier')"
  [ -z "$ids" ] && return 0
  while IFS= read -r id; do
    info "unloading model: $model ($id)"
    lms unload "$id"
  done <<< "$ids"
}

info "runtime: $RUNTIME  base_url: $RUNTIME_BASE_URL"

for model in "${MODEL_ARR[@]}"; do
  if [ "$RUNTIME" = lms ]; then
    # Clear any stale instances before loading (":2" variants survive across runs).
    lms_unload_model "$model"
    info "loading model: $model"
    bench_ttl_secs=$(( BENCH_TTL_MINUTES * 60 ))
    lms load --yes --ttl="$bench_ttl_secs" --context-length "$BENCH_CONTEXT" --parallel "$BENCH_PARALLEL" "$model"
    _lms_rc=$?
    if [ $_lms_rc -eq 130 ] || [ $_lms_rc -eq 143 ]; then exit $_lms_rc; fi
    if [ $_lms_rc -ne 0 ]; then warn "lms load failed for $model — skipping"; continue; fi
  else
    info "model: $model  (${RUNTIME} manages loading)"
  fi

  for adapter in "${ADAPTER_ARR[@]}"; do
    # Prefer a runtime-specific adapter (e.g. hermes-ollama.sh) if one exists.
    adapter_sh="$ADAPTERS_DIR/$adapter-$RUNTIME.sh"
    [ -f "$adapter_sh" ] || adapter_sh="$ADAPTERS_DIR/$adapter.sh"
    [ -f "$adapter_sh" ] || { warn "no adapter $adapter.sh — skipping"; continue; }
    command -v "$adapter" >/dev/null 2>&1 || { warn "$adapter not installed — skipping"; continue; }

    for case_id in "${CASE_ARR[@]}"; do
      case_src="$CASES_DIR/$case_id"
      [ -f "$case_src/meta.json" ] || { warn "no case $case_id — skipping"; continue; }

      base_sandbox="$RUN_DIR/sandbox/$adapter/$(fs_safe "$model")/$case_id"

      # --- run N trials, collecting per-trial pass/seconds/status ----------
      scores=(); secs=(); statuses=(); total=0; n_ok=0
      for ((t=1; t<=TRIALS; t++)); do
        if [ "$TRIALS" -gt 1 ]; then sandbox="$base_sandbox/trial-$t"; else sandbox="$base_sandbox"; fi
        read -r t_pass t_total t_elapsed t_status < <(run_trial "$adapter_sh" "$model" "$case_src" "$sandbox")
        total="$t_total"
        if [ "$t_total" -gt 0 ]; then t_score="$(awk "BEGIN{printf \"%.4f\", $t_pass/$t_total}")"; else t_score="0"; fi
        scores+=("$t_score"); secs+=("$t_elapsed"); statuses+=("$t_status")
        [ "$t_status" = ok ] && n_ok=$((n_ok+1))
        [ "$TRIALS" -gt 1 ] && \
          echo "$adapter,$model,$case_id,$t,$t_pass,$t_total,$(awk "BEGIN{printf \"%.2f\", $t_score}"),$t_elapsed,$t_status" >> "$TRIALS_CSV"
      done

      # --- collapse trials into medians ------------------------------------
      score="$(awk "BEGIN{printf \"%.2f\", $(median "${scores[@]}")}")"
      elapsed="$(awk "BEGIN{printf \"%.0f\", $(median "${secs[@]}")}")"
      # pass derived from the median score so it stays an integer consistent with score.
      pass="$(awk "BEGIN{printf \"%.0f\", $score*$total}")"
      # status: single status if all trials agree, else the distinct set joined with |.
      status="$(printf '%s\n' "${statuses[@]}" | sort -u | paste -sd'|' -)"

      echo "$adapter,$model,$case_id,$pass,$total,$score,$elapsed,$status,$TRIALS,$RUNTIME" >> "$CSV"

      # --- report ----------------------------------------------------------
      sec_note="${elapsed}s"; [ "$TRIALS" -gt 1 ] && sec_note="med ${elapsed}s, ${n_ok}/${TRIALS} ok"
      status_note=""; [ "$status" != "ok" ] && status_note=" $status"
      if   [ "$pass" = "$total" ] && [ "$total" -gt 0 ]; then ok   "$adapter | $model | $case_id  ->  $pass/$total  ${C_DIM}${sec_note}${C_RST}"
      elif [ "$pass" -gt 0 ]; then warn "$adapter | $model | $case_id  ->  $pass/$total  ${C_DIM}${sec_note}${status_note}${C_RST}"
      else err "$adapter | $model | $case_id  ->  $pass/$total  ${C_DIM}${sec_note}${status_note}${C_RST}"; fi

      # On any non-pass, point at the log so failures are diagnosable without
      # digging through the sandbox tree. --verbose adds a short error excerpt.
      if [ "$pass" != "$total" ] || [ "$total" -eq 0 ]; then
        logf="$sandbox/.bench.log"
        echo "      ${C_DIM}log: ${logf#"$HERE"/}${C_RST}"
        if [ "$VERBOSE" = 1 ] && [ -f "$logf" ]; then
          # MISS:/RESULT come from the grader (expected-vs-got per sub-test — the
          # most useful signal); the rest catch adapter/model/runtime errors.
          grep -aiE 'MISS:|^RESULT |error|refus|not ok|failed|exception|traceback|cannot|denied|no such' "$logf" \
            | grep -av '[⠁-⣿]' | tail -10 | sed "s/^/        ${C_DIM}| /; s/$/${C_RST}/"
        fi
      fi
    done
  done

  [ "$RUNTIME" = lms ] && lms_unload_model "$model"
done

echo
info "results: $CSV"
"$HERE/bin/report" "$CSV"

# ── Next steps hint ──────────────────────────────────────────────────────────
echo
echo "${C_DIM}Next steps:${C_RST}"
echo "${C_DIM}  bin/report --all                   # compare this run with all previous runs${C_RST}"
echo "${C_DIM}  bin/report --all --save            # persist merged leaderboard → LEADERBOARD.md${C_RST}"
echo "${C_DIM}  bin/gen-evals --all                # build context bundle for model/tool eval pages${C_RST}"
echo "${C_DIM}  bin/viz                            # rebuild interactive HTML dashboard${C_RST}"
