#!/usr/bin/env bash
# bin/report [options] [results.csv] — print leaderboards from a results CSV.
# Defaults to the newest run under results/.
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"; source "$HERE/lib/common.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") [options] [results.csv]

Options:
  -t, --tool TOOL[,TOOL...]    filter by adapter/tool (comma-separated)
  -m, --model MODEL[,MODEL...]  filter by model (comma-separated)
  -i, --interactive             use fzf to select tool(s) and model(s)
  -a, --all                     merge all runs under results/ (latest result
                                wins per adapter+model+case)
  --speed                       show speed comparison (avg seconds per case),
                                sorted fastest first
  --save [FILE]                 write leaderboards as markdown
                                (default: LEADERBOARD.md at repo root)
  --prune                       delete run directories whose every result is
                                superseded by a newer run (preview + confirm)
  --yes                         skip confirmation prompt when used with --prune
  -h, --help                    show this help

Defaults to the newest results CSV under $RESULTS_DIR.
EOF
  exit 0
}

TOOL_FILTER=""
MODEL_FILTER=""
RUNTIME_FILTER=""
INTERACTIVE=0
ALL_RUNS=0
SPEED=0
CSV=""
SAVE_MD=""
PRUNE=0
YES=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -t|--tool)    TOOL_FILTER="$2";    shift 2 ;;
    -m|--model)   MODEL_FILTER="$2";   shift 2 ;;
    -r|--runtime) RUNTIME_FILTER="$2"; shift 2 ;;
    -i|--interactive) INTERACTIVE=1; shift ;;
    -a|--all) ALL_RUNS=1; shift ;;
    --speed) SPEED=1; shift ;;
    --prune) PRUNE=1; shift ;;
    --yes)   YES=1;   shift ;;
    --save)
      case "${2:-}" in
        ""|-*) SAVE_MD="$HERE/LEADERBOARD.md"; shift ;;
        *)     SAVE_MD="$2"; shift 2 ;;
      esac ;;
    -*) die "unknown option: $1" ;;
    *) CSV="$1"; shift ;;
  esac
done

# ── Prune: remove run directories fully superseded by newer runs ─────────────
if [ "$PRUNE" -eq 1 ]; then
  ALL_CSVS="$(ls -d "$RESULTS_DIR"/*/results.csv 2>/dev/null | sort -r)"
  [ -n "$ALL_CSVS" ] || die "no results found in $RESULTS_DIR"

  # Walk newest-first; a run is prunable if ALL its (adapter,model,case,runtime)
  # keys already appear in strictly newer runs.
  declare -A _seen
  declare -a _prune_dirs _prune_sizes
  while IFS= read -r csv; do
    run_dir="$(dirname "$csv")"
    # Collect keys for this run.
    mapfile -t _keys < <(
      awk -F, 'NR>1 {rt=($10!=""?$10:"lms"); print $1 FS $2 FS $3 FS rt}' "$csv"
    )
    if [ "${#_keys[@]}" -eq 0 ]; then
      # Empty/header-only CSV — safe to prune.
      _sz="$(du -sh "$run_dir" 2>/dev/null | cut -f1)"
      _prune_dirs+=("$run_dir")
      _prune_sizes+=("${_sz:-?}")
    else
      _all_seen=1
      for _k in "${_keys[@]}"; do
        if [ -z "${_seen[$_k]:-}" ]; then _all_seen=0; break; fi
      done
      if [ "$_all_seen" -eq 1 ]; then
        _sz="$(du -sh "$run_dir" 2>/dev/null | cut -f1)"
        _prune_dirs+=("$run_dir")
        _prune_sizes+=("${_sz:-?}")
      fi
    fi
    # Register keys from this run as covered.
    for _k in "${_keys[@]}"; do _seen[$_k]=1; done
  done <<< "$ALL_CSVS"

  if [ "${#_prune_dirs[@]}" -eq 0 ]; then
    ok "Nothing to prune — no fully-superseded runs found."
    exit 0
  fi

  echo "${C_BLD}Runs to prune (all results superseded by newer runs):${C_RST}"
  for i in "${!_prune_dirs[@]}"; do
    printf "  %s  %s\n" "${_prune_sizes[$i]}" "$(basename "${_prune_dirs[$i]}")"
  done
  echo
  _total_bytes=0
  for d in "${_prune_dirs[@]}"; do
    _b="$(du -sk "$d" 2>/dev/null | cut -f1)"; _total_bytes=$(( _total_bytes + ${_b:-0} ))
  done
  printf "  %d director%s  (~%s MB)\n" \
    "${#_prune_dirs[@]}" \
    "$([ "${#_prune_dirs[@]}" -eq 1 ] && echo y || echo ies)" \
    "$(awk "BEGIN{printf \"%.1f\", $_total_bytes/1024}")"
  echo

  if [ "$YES" -ne 1 ]; then
    printf "Delete these directories? [y/N] "
    read -r _confirm
    [[ "$_confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
  fi

  for d in "${_prune_dirs[@]}"; do
    rm -rf "$d"
    echo "  ${C_DIM}removed: $(basename "$d")${C_RST}"
  done
  ok "Pruned ${#_prune_dirs[@]} run director$([ "${#_prune_dirs[@]}" -eq 1 ] && echo y || echo ies)."
  exit 0
fi

if [ "$ALL_RUNS" -eq 1 ]; then
  # Merge all runs: latest result wins per (adapter,model,case).
  # CSVs are listed newest-first; awk skips a key it has already seen.
  MERGED="$(mktemp)"
  trap 'rm -f "$MERGED"' EXIT
  # Sort by directory name (YYYYMMDD-HHMMSS), not mtime: mtime can be updated by
  # later reads/writes and would cause an older run to shadow a newer one.
  ALL_CSVS="$(ls -d "$RESULTS_DIR"/*/results.csv 2>/dev/null | sort -r)"
  [ -n "$ALL_CSVS" ] || die "no results found in $RESULTS_DIR"
  head -1 "$(echo "$ALL_CSVS" | head -1)" > "$MERGED"
  # Dedup key: adapter+model+case+runtime ($10, empty in old CSVs → groups as "lms").
  awk -F, 'FNR==1{next} !seen[$1,$2,$3,$10]++' $ALL_CSVS >> "$MERGED"
  CSV="$MERGED"
elif [ -z "$CSV" ]; then
  CSV="$(ls -d "$RESULTS_DIR"/*/results.csv 2>/dev/null | sort -r | head -1)"
  [ -n "$CSV" ] || die "no results found in $RESULTS_DIR"
fi
[ -f "$CSV" ] || die "no such file: $CSV"

if [ "$INTERACTIVE" -eq 1 ]; then
  command -v fzf >/dev/null 2>&1 || die "fzf not found; install it or use -t/-m flags"

  if [ -z "$TOOL_FILTER" ]; then
    available_tools="$(awk -F, 'NR>1 {print $1}' "$CSV" | sort -u)"
    selected_tools="$(echo "$available_tools" \
      | fzf --multi --prompt="Select tool(s): " \
            --header="TAB=multi-select  ENTER=confirm  ESC=all")"
    [ -n "$selected_tools" ] && TOOL_FILTER="$(echo "$selected_tools" | paste -sd,)"
  fi

  if [ -z "$MODEL_FILTER" ]; then
    available_models="$(lms ls 2>/dev/null | grep '/' | awk '{print $1}')"
    if [ -z "$available_models" ]; then
      available_models="$(awk -F, 'NR>1 {print $2}' "$CSV" | sort -u)"
    fi
    selected_models="$(echo "$available_models" \
      | fzf --multi --prompt="Select model(s): " \
            --header="TAB=multi-select  ENTER=confirm  ESC=all")"
    [ -n "$selected_models" ] && MODEL_FILTER="$(echo "$selected_models" | paste -sd,)"
  fi
fi

# Pre-filter the CSV if any filter is active, keeping the header row.
WORK_CSV="$CSV"
if [ -n "$TOOL_FILTER" ] || [ -n "$MODEL_FILTER" ] || [ -n "$RUNTIME_FILTER" ]; then
  WORK_CSV="$(mktemp)"
  trap 'rm -f "$WORK_CSV"' EXIT
  head -1 "$CSV" > "$WORK_CSV"
  awk -F, -v tf="$TOOL_FILTER" -v mf="$MODEL_FILTER" -v rf="$RUNTIME_FILTER" '
  NR == 1 { next }
  {
    if (tf != "") {
      n = split(tf, a, ","); ok = 0
      for (i = 1; i <= n; i++) if (a[i] == $1) { ok = 1; break }
      if (!ok) next
    }
    if (mf != "") {
      n = split(mf, a, ","); ok = 0
      for (i = 1; i <= n; i++) if (a[i] == $2) { ok = 1; break }
      if (!ok) next
    }
    if (rf != "") {
      # col 10 = runtime; old CSVs have no col 10 → treated as "lms"
      rt = ($10 != "" ? $10 : "lms")
      n = split(rf, a, ","); ok = 0
      for (i = 1; i <= n; i++) if (a[i] == rt) { ok = 1; break }
      if (!ok) next
    }
    print
  }' "$CSV" >> "$WORK_CSV"
fi

# Show active filters
[ -n "$TOOL_FILTER"    ] && echo "${C_DIM}tool filter:    $TOOL_FILTER${C_RST}"
[ -n "$MODEL_FILTER"   ] && echo "${C_DIM}model filter:   $MODEL_FILTER${C_RST}"
[ -n "$RUNTIME_FILTER" ] && echo "${C_DIM}runtime filter: $RUNTIME_FILTER${C_RST}"

# Each CSV row is already a per-(adapter,model,case) median across $9 trials
# (or a single trial when $9 is 1/absent), so the leaderboards aggregate medians.
maxtrials="$(awk -F, 'NR>1 && $9+0>m {m=$9+0} END{print m+0}' "$WORK_CSV")"
[ "$maxtrials" -gt 1 ] 2>/dev/null \
  && echo "${C_DIM}scores & seconds are per-case medians across up to ${maxtrials} trials${C_RST}"

# Rows are emitted with a leading hidden sort key (PASS%) + a TAB, sorted
# numerically descending, then the key is stripped with `cut`. Keeping adapter
# and model in separate awk arrays (keyed by SUBSEP) avoids splitting a display
# string on " | ", which awk would mis-parse as a regex alternation.
src_label="$CSV"
[ "$ALL_RUNS" -eq 1 ] && src_label="all runs (latest per adapter+model+case)"
echo "${C_BLD}Leaderboard — by runtime${C_RST}  ${C_DIM}($src_label)${C_RST}"
printf "  %-8s %8s %8s %7s\n" "RUNTIME" "TESTS" "PASS%" "avg s"
awk -F, 'NR>1 {
  rt = ($10 != "" ? $10 : "lms")
  p[rt]+=$4; t[rt]+=$5; sec[rt]+=$7; n[rt]++
}
END {
  for (r in p) {
    pct  = t[r]>0 ? 100*p[r]/t[r] : 0
    avgs = n[r]>0 ? sec[r]/n[r]   : 0
    printf "%09.4f\t  %-8s %4d/%-4d %7.1f%% %7.1f\n", pct, r, p[r], t[r], pct, avgs
  }
}' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-

echo
echo "${C_BLD}Leaderboard — by adapter x model${C_RST}  ${C_DIM}($src_label)${C_RST}"
printf "  %-8s %-9s %-26s %8s %8s %7s %6s\n" "RUNTIME" "ADAPTER" "MODEL" "TESTS" "PASS%" "med s" "trials"
awk -F, 'NR>1 {
  rt = ($10 != "" ? $10 : "lms")
  k=$1 SUBSEP $2 SUBSEP rt; ad[k]=$1; mo[k]=$2; ru[k]=rt
  p[k]+=$4; t[k]+=$5; n[k]++; sec[k]+=$7; if($9+0>tr[k]) tr[k]=$9+0
}
END {
  for (k in p) {
    pct = t[k]>0 ? 100*p[k]/t[k] : 0
    printf "%09.4f\t  %-8s %-9s %-26s %4d/%-4d %7.1f%% %6.1f %6d\n", \
      pct, ru[k], ad[k], mo[k], p[k], t[k], pct, sec[k]/n[k], (tr[k]<1?1:tr[k])
  }
}' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-

echo
echo "${C_BLD}Leaderboard — by model (all adapters)${C_RST}"
printf "  %-8s %-26s %8s %8s %7s\n" "RUNTIME" "MODEL" "TESTS" "PASS%" "avg s"
awk -F, 'NR>1 {
  rt = ($10 != "" ? $10 : "lms")
  k=$2 SUBSEP rt; mo[k]=$2; ru[k]=rt
  p[k]+=$4; t[k]+=$5; sec[k]+=$7; n[k]++
}
END {
  for (k in p) {
    pct  = t[k]>0 ? 100*p[k]/t[k] : 0
    avgs = n[k]>0 ? sec[k]/n[k]   : 0
    printf "%09.4f\t  %-8s %-26s %4d/%-4d %7.1f%% %7.1f\n", \
      pct, ru[k], mo[k], p[k], t[k], pct, avgs
  }
}' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-

echo
echo "${C_BLD}Leaderboard — by adapter (all models)${C_RST}"
printf "  %-9s %8s %8s %7s\n" "ADAPTER" "TESTS" "PASS%" "avg s"
awk -F, 'NR>1 { ad[$1]=$1; p[$1]+=$4; t[$1]+=$5; sec[$1]+=$7; n[$1]++ }
END {
  for (a in p) {
    pct  = t[a]>0 ? 100*p[a]/t[a] : 0
    avgs = n[a]>0 ? sec[a]/n[a]   : 0
    printf "%09.4f\t  %-9s %4d/%-4d %7.1f%% %7.1f\n", \
      pct, ad[a], p[a], t[a], pct, avgs
  }
}' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-

# Speed comparison (if requested)
if [ "$SPEED" -eq 1 ]; then
  echo
  echo "${C_BLD}Speed Comparison — by adapter (fastest first)${C_RST}"
  printf "  %-9s %8s %7s %7s\n" "ADAPTER" "CASES" "avg s" "Pass%"
  awk -F, 'NR>1 { ad[$1]=$1; p[$1]+=$4; t[$1]+=$5; sec[$1]+=$7; n[$1]++ }
  END {
    for (a in p) {
      pct  = t[a]>0 ? 100*p[a]/t[a] : 0
      avgs = n[a]>0 ? sec[a]/n[a]   : 0
      printf "%09.2f\t  %-9s %4d/%-4d %7.1f %7.1f%%\n", avgs, ad[a], n[a], n[a], avgs, pct
    }
  }' "$WORK_CSV" | sort -t$'\t' -k1 -n | cut -f2-
fi

if [ -n "$SAVE_MD" ]; then
  src_label="$CSV"
  [ "$ALL_RUNS" -eq 1 ] && src_label="all runs (latest per adapter+model+case)"
  {
    echo "# Benchmark Report"
    echo
    printf '**Source:** `%s`\n' "$src_label"
    printf '**Generated:** %s\n' "$(date '+%Y-%m-%d %H:%M')"
    [ -n "$TOOL_FILTER"  ] && printf '**Tool filter:** `%s`\n'  "$TOOL_FILTER"
    [ -n "$MODEL_FILTER" ] && printf '**Model filter:** `%s`\n' "$MODEL_FILTER"
    echo
    echo "## Leaderboard — by runtime"
    echo
    echo "| Runtime | Pass | Pass% | Avg s |"
    echo "|---------|------|-------|-------|"
    awk -F, 'NR>1 {
      rt = ($10 != "" ? $10 : "lms")
      p[rt]+=$4; t[rt]+=$5; sec[rt]+=$7; n[rt]++
    }
    END {
      for (r in p) {
        pct  = t[r]>0 ? 100*p[r]/t[r] : 0
        avgs = n[r]>0 ? sec[r]/n[r]   : 0
        printf "%09.4f\t| %s | %d/%d | %.1f%% | %.1f |\n", pct, r, p[r], t[r], pct, avgs
      }
    }' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-
    echo
    echo "## Leaderboard — by adapter × model"
    echo
    echo "| Runtime | Adapter | Model | Pass | Pass% | Avg s | Trials |"
    echo "|---------|---------|-------|------|-------|-------|--------|"
    awk -F, 'NR>1 {
      rt = ($10 != "" ? $10 : "lms")
      k=$1 SUBSEP $2 SUBSEP rt; ad[k]=$1; mo[k]=$2; ru[k]=rt
      p[k]+=$4; t[k]+=$5; n[k]++; sec[k]+=$7; if($9+0>tr[k]) tr[k]=$9+0
    }
    END {
      for (k in p) {
        pct = t[k]>0 ? 100*p[k]/t[k] : 0
        printf "%09.4f\t| %s | %s | %s | %d/%d | %.1f%% | %.1f | %d |\n", \
          pct, ru[k], ad[k], mo[k], p[k], t[k], pct, sec[k]/n[k], (tr[k]<1?1:tr[k])
      }
    }' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-
    echo
    echo "## Leaderboard — by model"
    echo
    echo "| Runtime | Model | Pass | Pass% | Avg s |"
    echo "|---------|-------|------|-------|-------|"
    awk -F, 'NR>1 {
      rt = ($10 != "" ? $10 : "lms")
      k=$2 SUBSEP rt; mo[k]=$2; ru[k]=rt
      p[k]+=$4; t[k]+=$5; sec[k]+=$7; n[k]++
    }
    END {
      for (k in p) {
        pct  = t[k]>0 ? 100*p[k]/t[k] : 0
        avgs = n[k]>0 ? sec[k]/n[k]   : 0
        printf "%09.4f\t| %s | %s | %d/%d | %.1f%% | %.1f |\n", \
          pct, ru[k], mo[k], p[k], t[k], pct, avgs
      }
    }' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-
    echo
    echo "## Leaderboard — by adapter"
    echo
    echo "| Adapter | Pass | Pass% | Avg s |"
    echo "|---------|------|-------|-------|"
    awk -F, 'NR>1 { ad[$1]=$1; p[$1]+=$4; t[$1]+=$5; sec[$1]+=$7; n[$1]++ }
    END {
      for (a in p) {
        pct  = t[a]>0 ? 100*p[a]/t[a] : 0
        avgs = n[a]>0 ? sec[a]/n[a]   : 0
        printf "%09.4f\t| %s | %d/%d | %.1f%% | %.1f |\n", \
          pct, ad[a], p[a], t[a], pct, avgs
      }
    }' "$WORK_CSV" | sort -t$'\t' -k1 -rn | cut -f2-
  } > "$SAVE_MD"
  ok "Markdown saved → $SAVE_MD"
fi

# ── Next steps hint ──────────────────────────────────────────────────────────
echo
echo "${C_DIM}Next steps:${C_RST}"
[ "$ALL_RUNS" -eq 0 ] && \
  echo "${C_DIM}  bin/report --all                   # merge all historical runs${C_RST}"
[ -z "$SAVE_MD" ] && \
  echo "${C_DIM}  bin/report --all --save            # persist merged leaderboard → LEADERBOARD.md${C_RST}"
echo "${C_DIM}  bin/gen-evals --all                # build context bundle for eval pages${C_RST}"
echo "${C_DIM}  bin/viz                            # rebuild interactive HTML dashboard${C_RST}"
