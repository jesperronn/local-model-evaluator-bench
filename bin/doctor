#!/usr/bin/env bash
# bin/doctor — verify the environment: server up, CLIs installed, models present.
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"; source "$HERE/lib/common.sh"

info "LM Studio server: $LMS_BASE_URL"
if lms_up; then
  ok "reachable"
  loaded="$(lms_loaded_models)"
  if [ -n "$loaded" ]; then
    echo "  loaded model ids:"; printf '    %s\n' $loaded
  else
    warn "no model currently loaded — load one in LM Studio or run: lms load <id>"
  fi
else
  err "not reachable. Start it with:  lms server start"
fi

echo
info "Model management CLIs:"
if command -v hf >/dev/null 2>&1; then
  ok "hf -> $(command -v hf)"
else
  warn "hf not found — bin/lms_update needs it: brew install hf"
fi

echo
info "Coding CLIs (adapters in $ADAPTERS_DIR):"
for a in "$ADAPTERS_DIR"/*.sh; do
  name="$(basename "$a" .sh)"
  if command -v "$name" >/dev/null 2>&1; then ok "$name -> $(command -v "$name")"
  else warn "$name not on PATH (adapter present, tool missing)"; fi
done

echo
info "hermes readiness (its tools run in a sandbox that must reach the cwd):"
if command -v hermes >/dev/null 2>&1; then
  cfg="$HOME/.hermes/config.yaml"
  backend="$(grep -A1 '^terminal:' "$cfg" 2>/dev/null | sed -nE 's/^[[:space:]]*backend:[[:space:]]*([a-z]+).*/\1/p' | head -1)"
  mount="$(grep -E 'docker_mount_cwd_to_workspace:' "$cfg" 2>/dev/null | sed -nE 's/.*:[[:space:]]*([a-z]+).*/\1/p' | head -1)"
  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then dkr=up; else dkr=down; fi
  if [ "$backend" = local ]; then
    ok "backend=local (runs on host, no sandbox) — edits reach the cwd"
  elif [ "$backend" = docker ] && [ "$mount" = true ] && [ "$dkr" = up ]; then
    ok "backend=docker + cwd mounted + docker up — ready (isolation kept)"
  else
    warn "NOT ready: backend=${backend:-?} mount=${mount:-?} docker=$dkr"
    echo "    In $cfg under 'terminal:' set ONE of:"
    echo "      backend: docker   AND   docker_mount_cwd_to_workspace: true   (safe: keeps container isolation; needs Docker running + image)"
    echo "      backend: local                                                (runs --yolo tools directly on the host — no sandbox)"
    echo "    Then add 'hermes' to DEFAULT_ADAPTERS in config.sh."
  fi
else
  echo "    hermes not installed — skipping"
fi

echo
info "Models under test ($MODELS_FILE):"
read_list "$MODELS_FILE" | sed 's/^/    /'

echo
info "Test cases ($CASES_DIR):"
for d in "$CASES_DIR"/*/; do
  [ -f "$d/meta.json" ] || continue
  id="$(basename "$d")"
  lang="$(grep -oE '"lang"\s*:\s*"[^"]+"' "$d/meta.json" | sed -E 's/.*"([^"]+)"$/\1/')"
  printf '    %-26s [%s]\n' "$id" "$lang"
done

echo
info "Coverage gaps (missing adapter × model × case combos):"
RESULTS_DIR="$RESULTS_DIR" python3 - << 'PYEOF'
import glob, csv, os, sys
from collections import defaultdict

results_dir = os.environ['RESULTS_DIR']
latest = {}
for path in sorted(glob.glob(results_dir + '/*/results.csv')):
    run = os.path.basename(os.path.dirname(path))
    try:
        with open(path) as f:
            for row in csv.DictReader(f):
                k = (row['adapter'], row['model'], row['case'])
                if k not in latest or run > latest[k]['run']:
                    latest[k] = {**row, 'run': run}
    except Exception:
        pass

if not latest:
    print('  no results found yet')
    sys.exit(0)

adapters = sorted(set(k[0] for k in latest))
models   = sorted(set(k[1] for k in latest))
cases    = sorted(set(k[2] for k in latest))

# track runtime per (adapter, model)
runtime_for = {}
for (adapter, model, case), row in latest.items():
    runtime_for[(adapter, model)] = row.get('runtime', 'lms')

missing = defaultdict(lambda: defaultdict(list))
for adapter in adapters:
    for model in models:
        has_any = any((adapter, model, c) in latest for c in cases)
        if not has_any:
            continue
        for case in cases:
            if (adapter, model, case) not in latest:
                missing[adapter][model].append(case)

total = sum(len(cs) for m in missing.values() for cs in m.values())
if total == 0:
    print('  all combinations complete!')
else:
    print(f'  {total} missing. Commands to fill the gaps:\n')
    for adapter in sorted(missing):
        for model in sorted(missing[adapter]):
            cases_list = ','.join(missing[adapter][model])
            runtime = runtime_for.get((adapter, model), 'lms')
            print(f'  bin/bench --runtime {runtime} --agent {adapter} --model {model} --cases {cases_list}')
        print()
PYEOF
