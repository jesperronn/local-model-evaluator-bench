cat << 'VIZ_END'
function shortModel(m){return m.split('/').pop();}
function fmtFrac(p,t){return t?`${p}/${t}`:'—';}
function fmtPct(s){return (s*100).toFixed(0)+'%';}
function fmtTime(s){return s>=60?(s/60).toFixed(1)+'m':s+'s';}
function scoreCls(v){return v>=0.75?'good':v>=0.5?'mid':'bad';}
function esc(s){return String(s).replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;');}
function ent(kind,name,label,extra=''){return `<span class="entity" data-entity-kind="${kind}" data-entity-name="${esc(name)}"${extra}>${label}</span>`;}

function latestComboRuntime(rows){
  const map=new Map();
  for(const r of rows){
    const k=[r.adapter,r.model,r.runtime,r.case].join('|');
    if(!map.has(k)||r.run>map.get(k).run) map.set(k,r);
  }
  return [...map.values()];
}

function aggregate(rows){
  const agents=new Map(), modelRows=[];
  for(const r of rows){
    const ak=r.adapter;
    if(!agents.has(ak)) agents.set(ak,{adapter:r.adapter,pass:0,total:0,secs:0,models:new Map(),ok:0,timeout:0,error:0});
    const a=agents.get(ak);
    a.pass+=r.pass; a.total+=r.total; a.secs+=r.seconds;
    if(r.status==='ok') a.ok++; else if((r.status||'').includes('timeout')) a.timeout++; else a.error++;
    const mk=r.model;
    if(!a.models.has(mk)) a.models.set(mk,{model:r.model,pass:0,total:0,secs:0,cases:0});
    const m=a.models.get(mk);
    m.pass+=r.pass; m.total+=r.total; m.secs+=r.seconds; m.cases++;
  }
  return [...agents.values()].map(a=>{
    const top=[...a.models.values()]
      .map(m=>({...m,score:m.total?m.pass/m.total:0}))
      .sort((x,y)=>y.score-x.score||x.secs-y.secs)
      .slice(0,5);
    return {...a,score:a.total?a.pass/a.total:0,modelCount:a.models.size,top};
  }).sort((x,y)=>y.score-x.score||x.secs-y.secs);
}

function renderRuntime(rt, rows){
  const agg=aggregate(rows);
  const modelSet=new Set(rows.map(r=>r.model));
  const cases=new Set(rows.map(r=>r.case));
  return `<section class="rt">
    <h2>${ent('runtime',rt||'—',rt||'—')} <span class="muted" style="font-size:13px;font-weight:400">· ${rows.length} rows · ${modelSet.size} models · ${cases.size} cases</span></h2>
    <div class="grid">
      <div class="card">
        <h3>Agent Leaderboard</h3>
        <table>
          <thead><tr><th>Agent</th><th>Pass</th><th>Pass %</th><th>Time</th><th>Models</th><th>Status mix</th></tr></thead>
          <tbody>
            ${agg.map(a=>`<tr>
              <td><strong>${ent('agent',a.adapter,a.adapter)}</strong></td>
              <td class="mono">${fmtFrac(a.pass,a.total)}</td>
              <td class="mono ${scoreCls(a.score)}">${fmtPct(a.score)}</td>
              <td class="mono">${fmtTime(a.secs)}</td>
              <td class="mono">${a.modelCount}</td>
              <td class="mono tight muted">ok ${a.ok} · timeout ${a.timeout} · err ${a.error}</td>
            </tr>`).join('')}
          </tbody>
        </table>
      </div>
      <div class="card">
        <h3>Top 5 Models Per Agent</h3>
        <table>
          <thead><tr><th>Agent</th><th>Best models</th></tr></thead>
          <tbody>
            ${agg.map(a=>`<tr>
              <td><strong>${ent('agent',a.adapter,a.adapter)}</strong></td>
              <td>${a.top.map(m=>`<span class="pill">${ent('model',m.model,`<strong>${esc(shortModel(m.model))}</strong>`)} <span class="${scoreCls(m.score)}">${fmtFrac(m.pass,m.total)}</span> <span class="muted">${fmtTime(m.secs)}</span></span>`).join('')}</td>
            </tr>`).join('')}
          </tbody>
        </table>
      </div>
    </div>
  </section>`;
}

const rows=latestComboRuntime(DATA).filter(r=>r.runtime);
const runtimes=[...new Set(rows.map(r=>r.runtime))].sort();
document.getElementById('app').innerHTML=runtimes.map(rt=>renderRuntime(rt, rows.filter(r=>r.runtime===rt))).join('');

let hoverKey='';
function setHover(kind,name){
  const key=kind+'|'+name;
  if(hoverKey===key) return;
  hoverKey=key;
  const nodes=[...document.querySelectorAll('[data-entity-kind]')];
  nodes.forEach(node=>{
    const match=node.dataset.entityKind===kind && node.dataset.entityName===name;
    node.classList.toggle('entity-match', match);
    node.classList.toggle('entity-dim', !match);
  });
}
function clearHover(){
  hoverKey='';
  document.querySelectorAll('[data-entity-kind]').forEach(node=>{
    node.classList.remove('entity-match','entity-dim');
  });
}
document.addEventListener('mouseover', e=>{
  const t=e.target.closest('[data-entity-kind]');
  if(!t) return;
  setHover(t.dataset.entityKind, t.dataset.entityName);
});
document.addEventListener('mouseout', e=>{
  const from=e.target.closest('[data-entity-kind]');
  if(!from) return;
  const to=e.relatedTarget && e.relatedTarget.closest ? e.relatedTarget.closest('[data-entity-kind]') : null;
  if(to && to.dataset.entityKind===from.dataset.entityKind && to.dataset.entityName===from.dataset.entityName) return;
  clearHover();
});
</script>
</body>
</html>
VIZ_END
} > "$PROTO_OUT"

