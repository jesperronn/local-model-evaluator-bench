# ── Embedded data (dynamically generated) ────────────────────────────────────
printf 'const DATA = %s;\n' "$data_json"
printf 'const CASE_TOTALS = %s;\n' "$case_totals_json"

# ── JS logic (static) ────────────────────────────────────────────────────────
cat << 'VIZ_END'
const VIEWS = ['Scatter','Heatmap','Bars','Leaderboard','Table','By Task'];

const ADAPTER_COLORS = {
  aider:'#0969da', opencode:'#1a7f37', codex:'#d4371c',
  hermes:'#6e40c9', caveman:'#bf3989'
};
const FAMILY_COLORS = {google:'#f97316', qwen:'#8b5cf6'};

// 12 unique Chart.js point shapes (avoid 'dash'/'line' — they render as hairlines).
// triangle supports 4 directions via rot: 0=▲ 90=▶ 180=▽ 270=◀
// rectRounded@45 renders as a rounded diamond (distinct from rectRot@0 which is sharp ◆).
//
// Symbol candidates for future picking — copy any into sym:'':
//   Filled solid:  ● ▲ ▽ ▶ ◀ ■ ◆ ★ ✚ ✕ ▣ ⬟ ⬡ ⬢ ◉ ◎ ✦ ✧ ✶ ✸ ✴ ❋ ❊
//   Outlined:      △ ▷ ▽ ◁ □ ◇ ☆ ✩ ◯ ○ ⊕ ⊗ ⊙ ⊞ ⊠ ⊡ ◈ ⬦ ⬧
//   Other shapes:  ⬤ ⬛ ⬜ ⬠ ⬡ ⬢ ⬣ ⬟ ⬦ ⏣ ❖ ✇ ⌖ ⌘ ⍟ ⎔ ⏻ ⏼ ⟐ ⟡
//   Superscript-y: ⊛ ⊜ ⊝ ⊶ ⊷ ⋄ ⋆ ⋇ ⋈ ⋉ ⋊ ⋋ ⋌ ⋍ ⋎ ⋏ ⋐ ⋑
const POINT_DEFS = [
  {style:'circle',       rot:0,   sym:'●'},
  {style:'triangle',     rot:0,   sym:'▲'},
  {style:'triangle',     rot:180, sym:'▽'},
  {style:'triangle',     rot:90,  sym:'▶'},
  {style:'triangle',     rot:270, sym:'◀'},
  {style:'rect',         rot:0,   sym:'■'},
  {style:'rectRot',      rot:0,   sym:'◆'},
  {style:'star',         rot:0,   sym:'★'},
  {style:'cross',        rot:0,   sym:'✚'},
  {style:'crossRot',     rot:0,   sym:'✕'},
  {style:'rectRounded',  rot:0,   sym:'▣'},
  {style:'rectRounded',  rot:45,  sym:'⬟'},
];

const S = {
  view:'Scatter', adapters:new Set(), models:new Set(), runtimes:new Set(), cases:new Set(),
  run:'latest-combo', scatterMode:'detail',
  hmMode:'score', hmGroupBy:'adapter',
  barMode:'score',
  lbGroupBy:'none', groupedDetail:'overall',
  tblSort:{col:'score',dir:'desc'}, tblSearch:'',
};

let C1=null, ALL_MODELS=[];

// ─── Helpers ────────────────────────────────────────────
// Fallback sizes for models whose names don't encode a parameter count.
const MODEL_SIZES = {
  'qwen/qwen3-coder-next': 80,
};
function parseSize(m){
  if(MODEL_SIZES[m]!=null)return MODEL_SIZES[m];
  const n=m.split('/').pop().toLowerCase();
  const e=n.match(/-e(\d+)b/); if(e)return parseInt(e[1]);
  const r=n.match(/-(\d+)b/);  if(r)return parseInt(r[1]);
  return null;
}
function pdef(m)  { return POINT_DEFS[ALL_MODELS.indexOf(m)%POINT_DEFS.length]||POINT_DEFS[0]; }
function sym(m)   { return pdef(m).sym; }
function scoreColor(s){ if(s==null)return '#f6f8fa'; return `hsl(${s*120},65%,${91-s*9}%)`; }
function timeColor(t,mx){ if(!mx||!t)return '#f6f8fa'; return `hsl(${(1-Math.min(t/mx,1))*110},55%,88%)`; }
function fmtFrac(p,t){ return t?`${p}/${t}`:'—'; }
function fmtPct(s)   { return s!=null?(s*100).toFixed(0)+'%':'—'; }
function fmtTime(s)  { if(s==null)return '—'; return s>=60?(s/60).toFixed(1)+'m':s+'s'; }
function shortModel(m){ return m.split('/').pop(); }
function ac(a){ return ADAPTER_COLORS[a]||'#888'; }
function fc(m){ return FAMILY_COLORS[m.split('/')[0]]||'#888'; }
function statusBadge(s){ const c=s==='ok'?'b-ok':s.includes('timeout')?'b-timeout':'b-error'; return `<span class="badge ${c}">${s}</span>`; }
function rankColor(i){ return ['#b45309','#6b7280','#92400e'][i]||'#9ca3af'; }
function rtBadge(g){
  const rts=[...(g.runtimes||[])].filter(Boolean);
  if(!rts.length)return'';
  return rts.map(rt=>`<span class="badge" style="background:#f0f4ff;color:#0969da;border:1px solid #b6d0f7">${rt}</span>`).join(' ');
}
function scoreCol(v){ return v>=0.75?'#1a7f37':v>=0.5?'#9a6700':'#cf222e'; }

// ─── Data ───────────────────────────────────────────────
function filteredRows(){
  let rows=DATA;
  if(S.run==='latest-combo'){
    const map=new Map();
    for(const r of rows){const k=r.adapter+'|'+r.model+'|'+r.case;if(!map.has(k)||r.run>map.get(k).run)map.set(k,r);}
    rows=[...map.values()];
  } else if(S.run==='latest-run'){
    const latest=rows.reduce((a,b)=>a.run>b.run?a:b).run;
    rows=rows.filter(r=>r.run===latest);
  }
  return rows.filter(r=>S.adapters.has(r.adapter)&&S.models.has(r.model)&&S.cases.has(r.case)&&S.runtimes.has(r.runtime));
}

function aggregated(rows, groupBy){
  if(!groupBy)groupBy='adapter';
  const byRt=groupBy==='runtime'||groupBy==='adapter+runtime';
  const sel=[...S.cases].sort();
  const map=new Map();
  for(const r of rows){
    const rt=r.runtime||'';
    const k=byRt?r.adapter+'|'+r.model+'|'+rt:r.adapter+'|'+r.model;
    if(!map.has(k))map.set(k,{adapter:r.adapter,model:r.model,runtime:rt,byCase:{},secs:0,runtimes:new Set()});
    const g=map.get(k);g.byCase[r.case]=r;g.secs+=r.seconds;if(r.runtime)g.runtimes.add(r.runtime);
  }
  return [...map.values()].map(g=>{
    let pass=0,total=0,scoreSum=0,attempted=0;
    for(const c of sel){
      const r=g.byCase[c];
      if(r){pass+=r.pass;total+=r.total;scoreSum+=r.score;attempted++;}
      else{total+=(CASE_TOTALS[c]||0);}
    }
    return{...g,pass,total,attempted,caseCount:sel.length,avgScore:sel.length?scoreSum/sel.length:0};
  }).sort((a,b)=>{
    if(groupBy!=='none'){
      if(groupBy!=='runtime'){const c=a.adapter.localeCompare(b.adapter);if(c)return c;}
      if(byRt){const c=(a.runtime||'').localeCompare(b.runtime||'');if(c)return c;}
    }
    return b.avgScore-a.avgScore||a.secs-b.secs;
  });
}

function groupKey(g, groupBy){
  if(groupBy==='runtime') return g.runtime||'—';
  if(groupBy==='adapter+runtime') return g.adapter+'\x00'+(g.runtime||'—');
  if(groupBy==='adapter') return g.adapter;
  return g.adapter+'|'+g.model+'|'+(g.runtime||'');
}

function groupHeader(g, groupBy){
  if(groupBy==='runtime'){
    return {label:g.runtime||'—', dotHtml:'', color:'var(--muted)'};
  }
  const dot=`background:${ac(g.adapter)};display:inline-block;width:8px;height:8px;border-radius:50%;vertical-align:middle;margin-right:5px`;
  if(groupBy==='adapter+runtime'){
    return {
      label:`${g.adapter} <span style="font-size:10px;font-weight:400;margin-left:4px;color:var(--muted)">· ${g.runtime||'—'}</span>`,
      dotHtml:`<span style="${dot}"></span>`,
      color:ac(g.adapter),
    };
  }
  return {label:g.adapter,dotHtml:`<span style="${dot}"></span>`,color:ac(g.adapter)};
}

function aggregateGroupRows(rows, groupBy){
  const cases=[...S.cases].sort();
  const modelAgg=aggregated(rows, groupBy);
  const map=new Map();
  for(const g of modelAgg){
    const key=groupKey(g, groupBy);
    if(!map.has(key)){
      map.set(key,{
        key, adapter:g.adapter, runtime:g.runtime, models:[],
        byCase:{}, pass:0, total:0, secs:0, attemptedModels:0,
      });
    }
    const out=map.get(key);
    out.models.push(g);
    out.pass+=g.pass;
    out.total+=g.total;
    out.secs+=g.secs;
    if(g.attempted===g.caseCount) out.attemptedModels++;
    for(const c of cases){
      const r=g.byCase[c];
      if(!out.byCase[c]) out.byCase[c]={pass:0,total:0,secs:0,n:0,ok:0,timeout:0,error:0};
      const cell=out.byCase[c];
      if(r){
        cell.pass+=r.pass;
        cell.total+=r.total;
        cell.secs+=r.seconds;
        cell.n++;
        if(r.status==='ok') cell.ok++;
        else if(r.status.includes('timeout')) cell.timeout++;
        else cell.error++;
      }
    }
  }
  return [...map.values()].map(g=>{
    const topModels=g.models
      .slice()
      .sort((a,b)=>b.avgScore-a.avgScore||a.secs-b.secs)
      .slice(0,5);
    return {
      ...g,
      avgScore:g.total?g.pass/g.total:0,
      modelCount:g.models.length,
      topModels,
    };
  }).sort((a,b)=>b.avgScore-a.avgScore||a.secs-b.secs);
}

function topModelsByGroup(rows, groupBy, limit){
  const items=aggregated(rows, groupBy);
  if(groupBy==='none') return items;
  const out=[];
  let currentKey=null, bucket=[];
  function flush(){
    if(!bucket.length) return;
    bucket
      .sort((a,b)=>b.avgScore-a.avgScore||a.secs-b.secs)
      .slice(0, limit)
      .forEach(x=>out.push(x));
    bucket=[];
  }
  for(const item of items){
    const key=groupKey(item, groupBy);
    if(currentKey!==null && key!==currentKey) flush();
    currentKey=key;
    bucket.push(item);
  }
  flush();
  return out;
}

// ─── Adapter chips ──────────────────────────────────────
function setAStyle(chip,a,on){
  const c=ac(a);
  chip.style.cssText=on?`background:${c};border-color:${c};color:#fff`:`background:${c}18;border-color:${c}55;color:${c}`;
}
function buildAdapterChips(adapters){
  const el=document.getElementById('f-adapters'); el.innerHTML='';
  const chips=[];
  adapters.forEach(a=>{
    const chip=document.createElement('span'); chip.className='chip';
    chip.textContent=a; setAStyle(chip,a,S.adapters.has(a));
    chip.onclick=e=>{
      if(e.metaKey||e.ctrlKey){
        const solo=!(S.adapters.size===1&&S.adapters.has(a));
        S.adapters.clear(); if(solo)S.adapters.add(a); else adapters.forEach(x=>S.adapters.add(x));
        chips.forEach((c,i)=>setAStyle(c,adapters[i],S.adapters.has(adapters[i])));
      } else {
        S.adapters.has(a)?S.adapters.delete(a):S.adapters.add(a);
        setAStyle(chip,a,S.adapters.has(a));
      }
      render();
    };
    el.appendChild(chip); chips.push(chip);
  });
}

// ─── Model chips (grouped by size) ──────────────────────
function buildModelChips(models){
  const el=document.getElementById('f-models'); el.innerHTML='';
  const bySize=new Map();
  for(const m of models){
    const sz=parseSize(m);
    if(!bySize.has(sz))bySize.set(sz,[]);
    bySize.get(sz).push(m);
  }
  const sortedSizes=[...bySize.keys()].sort((a,b)=>(a||0)-(b||0));

  sortedSizes.forEach((sz,sIdx)=>{
    const sModels=bySize.get(sz);
    const szLabel=(sz?sz+'B':'?B');
    if(sIdx>0){const sep=document.createElement('span');sep.className='size-sep';el.appendChild(sep);}

    const allOn=sModels.every(m=>S.models.has(m));
    const someOn=sModels.some(m=>S.models.has(m));
    const sBtn=document.createElement('span');
    sBtn.className='size-hdr '+(allOn?'all-on':someOn?'some-on':'none-on');
    sBtn.textContent=szLabel;
    sBtn.title=`Toggle all ${szLabel} models · ⌘+click to solo this size`;
    sBtn.onclick=e=>{
      if(e.metaKey||e.ctrlKey){
        const alreadySolo=S.models.size===sModels.length&&sModels.every(m=>S.models.has(m));
        S.models.clear();
        if(alreadySolo)models.forEach(m=>S.models.add(m)); else sModels.forEach(m=>S.models.add(m));
      } else {
        if(allOn)sModels.forEach(m=>S.models.delete(m)); else sModels.forEach(m=>S.models.add(m));
      }
      buildModelChips(models); render();
    };
    el.appendChild(sBtn);

    sModels.forEach(m=>{
      const chip=document.createElement('span');
      chip.className='chip'+(S.models.has(m)?' on':'');
      chip.textContent=sym(m)+' '+shortModel(m);
      chip.title=m+' ('+szLabel+')';
      chip.onclick=e=>{
        if(e.metaKey||e.ctrlKey){
          const solo=!(S.models.size===1&&S.models.has(m));
          S.models.clear(); if(solo)S.models.add(m); else models.forEach(x=>S.models.add(x));
        } else {
          S.models.has(m)?S.models.delete(m):S.models.add(m);
        }
        buildModelChips(models); render();
      };
      el.appendChild(chip);
    });
  });
}

function groupedModelSummaryActive(){
  if(!['Heatmap','Leaderboard'].includes(S.view)) return false;
  const groupBy=S.view==='Heatmap'?S.hmGroupBy:S.lbGroupBy;
  return groupBy!=='none' && S.groupedDetail!=='all';
}

function updateModelFilterUI(){
  const chips=document.getElementById('f-models');
  const summary=document.getElementById('f-model-summary');
  if(!chips||!summary) return;
  const total=ALL_MODELS.length;
  const selected=S.models.size;
  const hidden=groupedModelSummaryActive();
  chips.style.display=hidden?'none':'flex';
  summary.classList.toggle('on', hidden);
  summary.innerHTML=hidden
    ?`${selected}/${total} selected models <span class="muted">· model chips hidden in ${S.groupedDetail==='overall'?'Overall':'Top 5'} mode</span>`
    :'';
}

function buildRunChips(){
  const el=document.getElementById('f-run'); el.innerHTML='';
  [['latest-combo','Latest/combo'],['latest-run','Latest run'],['all','All runs']].forEach(([val,label])=>{
    const chip=document.createElement('span');
    chip.className='chip'+(S.run===val?' on':'');
    chip.textContent=label;
    chip.onclick=()=>{S.run=val;buildRunChips();render();};
    el.appendChild(chip);
  });
}

function buildChips(id,items,activeSet,labelFn){
  const el=document.getElementById(id); el.innerHTML='';
  const chips=[];
  items.forEach((item,idx)=>{
    const chip=document.createElement('span');
    chip.className='chip'+(activeSet.has(item)?' on':'');
    chip.textContent=labelFn?labelFn(item):item;
    chip.onclick=e=>{
      if(e.metaKey||e.ctrlKey){
        const solo=!(activeSet.size===1&&activeSet.has(item));
        activeSet.clear(); if(solo)activeSet.add(item); else items.forEach(x=>activeSet.add(x));
        chips.forEach((c,i)=>c.classList.toggle('on',activeSet.has(items[i])));
      } else {
        activeSet.has(item)?activeSet.delete(item):activeSet.add(item);
        chip.classList.toggle('on',activeSet.has(item));
      }
      render();
    };
    el.appendChild(chip); chips.push(chip);
  });
}

// ─── URL sync ───────────────────────────────────────────
function syncURL(){
  const p=new URLSearchParams();
  p.set('view',S.view);
  p.set('run',S.run);
  if(S.scatterMode!=='detail')      p.set('scatterMode',S.scatterMode);
  if(S.hmMode!=='score')            p.set('hmMode',S.hmMode);
  if(S.hmGroupBy!=='adapter')       p.set('hmGroupBy',S.hmGroupBy);
  if(S.barMode!=='score')           p.set('barMode',S.barMode);
  if(S.lbGroupBy!=='none')          p.set('lbGroupBy',S.lbGroupBy);
  if(S.groupedDetail!=='overall')   p.set('groupedDetail',S.groupedDetail);
  if(S.tblSearch)              p.set('q',S.tblSearch);
  if(S.tblSort.col!=='score'||S.tblSort.dir!=='desc') p.set('sort',S.tblSort.col+':'+S.tblSort.dir);
  p.set('adapters', [...S.adapters].sort().join(','));
  p.set('models',   [...S.models].sort().join(','));
  p.set('runtimes', [...S.runtimes].sort().join(','));
  p.set('cases',    [...S.cases].sort().join(','));
  history.replaceState(null,'','?'+p.toString());
}

function loadFromURL(){
  const p=new URLSearchParams(location.search);
  if(p.has('view')&&VIEWS.includes(p.get('view')))  S.view=p.get('view');
  if(p.has('run'))         S.run=p.get('run');
  if(p.has('scatterMode')) S.scatterMode=p.get('scatterMode');
  if(p.has('hmMode'))      S.hmMode=p.get('hmMode');
  if(p.has('hmGroupBy'))   S.hmGroupBy=p.get('hmGroupBy');
  if(p.has('barMode'))     S.barMode=p.get('barMode');
  if(p.has('lbGroupBy'))   S.lbGroupBy=p.get('lbGroupBy');
  if(p.has('groupedDetail')) S.groupedDetail=p.get('groupedDetail');
  if(p.has('q'))           S.tblSearch=p.get('q');
  if(p.has('sort')){const[col,dir]=p.get('sort').split(':');if(col&&dir)S.tblSort={col,dir};}
  return{
    adapters: p.has('adapters')  ?p.get('adapters').split(',').filter(Boolean) :null,
    models:   p.has('models')    ?p.get('models').split(',').filter(Boolean)   :null,
    runtimes: p.has('runtimes')  ?p.get('runtimes').split(',').filter(Boolean) :null,
    cases:    p.has('cases')     ?p.get('cases').split(',').filter(Boolean)    :null,
  };
}

// ─── Init ───────────────────────────────────────────────
function init(){
  const urlF=loadFromURL();
  const adapters=[...new Set(DATA.map(r=>r.adapter))].sort();
  ALL_MODELS=[...new Set(DATA.map(r=>r.model))].sort();
  const runtimes=[...new Set(DATA.map(r=>r.runtime))].sort();
  const cases=[...new Set(DATA.map(r=>r.case))].sort();
  const wantA=urlF.adapters||adapters;
  const wantM=urlF.models||ALL_MODELS;
  const wantR=urlF.runtimes||runtimes;
  const wantC=urlF.cases||cases;
  wantA.forEach(a=>{if(adapters.includes(a))S.adapters.add(a);});
  wantM.forEach(m=>{if(ALL_MODELS.includes(m))S.models.add(m);});
  wantR.forEach(rt=>{if(runtimes.includes(rt))S.runtimes.add(rt);});
  wantC.forEach(c=>{if(cases.includes(c))S.cases.add(c);});
  buildAdapterChips(adapters);
  buildModelChips(ALL_MODELS);
  buildRunChips();
  buildChips('f-runtimes',runtimes,S.runtimes,rt=>rt||'(none)');
  buildChips('f-cases',cases,S.cases,c=>c.replace(/^\w+-\d+-/,''));
  updateModelFilterUI();
  const tabsEl=document.getElementById('view-tabs');
  VIEWS.forEach(v=>{
    const b=document.createElement('button');
    b.className='vtab'+(v===S.view?' on':'');
    b.textContent=v;
    b.onclick=()=>{S.view=v;document.querySelectorAll('.vtab').forEach(t=>t.classList.toggle('on',t.textContent===S.view));render();};
    tabsEl.appendChild(b);
  });
  render();
}

// ─── Render ─────────────────────────────────────────────
function render(){
  syncURL();
  if(C1){C1.destroy();C1=null;}
  updateModelFilterUI();
  const rows=filteredRows();
  const el=document.getElementById('view-content');
  document.getElementById('data-summary').textContent=rows.length+' rows · '+new Set(rows.map(r=>r.adapter+'|'+r.model)).size+' combos';
  if(!rows.length){el.innerHTML='<div class="card"><div class="empty">No data matches current filters.</div></div>';return;}
  ({Scatter:vScatter,Heatmap:vHeatmap,Bars:vBars,Leaderboard:vLeaderboard,Table:vTable,'By Task':vByTask})[S.view](el,rows);
}

// ─── View 1: Scatter ────────────────────────────────────
function aggByAdapter(rows){
  const map=new Map();
  for(const r of rows){
    if(!map.has(r.adapter))map.set(r.adapter,{adapter:r.adapter,pass:0,total:0,secs:0,scores:[]});
    const g=map.get(r.adapter);g.pass+=r.pass;g.total+=r.total;g.secs+=r.seconds;g.scores.push(r.score);
  }
  return[...map.values()].map(g=>({...g,avgScore:g.scores.reduce((a,b)=>a+b,0)/g.scores.length}));
}
function aggByModel(rows){
  const map=new Map();
  for(const r of rows){
    if(!map.has(r.model))map.set(r.model,{model:r.model,pass:0,total:0,secs:0,scores:[]});
    const g=map.get(r.model);g.pass+=r.pass;g.total+=r.total;g.secs+=r.seconds;g.scores.push(r.score);
  }
  return[...map.values()].map(g=>({...g,avgScore:g.scores.reduce((a,b)=>a+b,0)/g.scores.length}));
}

function vScatter(el,rows){
  const mBtn=(label,mode)=>
    `<button class="btn${S.scatterMode===mode?' on':''}" onclick="S.scatterMode='${mode}';render()">${label}</button>`;

  el.innerHTML=`<div class="card">
    <div class="ctrl-row">${mBtn('Detail','detail')} ${mBtn('By Adapter','by-adapter')} ${mBtn('By Model','by-model')}</div>
    <div class="chart-wrap"><canvas id="C1"></canvas></div>
    <div class="chart-note" id="scatter-note"></div>
  </div>`;

  let datasets, note, showLabels=false, yMax=1;

  if(S.scatterMode==='by-adapter'){
    const agg=aggByAdapter(rows);
    yMax=Math.max(...agg.map(g=>g.total),1);
    datasets=agg.map(g=>({
      label:g.adapter,
      data:[{x:g.secs,y:g.pass,_g:g,_type:'adapter'}],
      backgroundColor:ac(g.adapter)+'cc',borderColor:ac(g.adapter),
      borderWidth:2,pointStyle:'circle',pointRadius:14,pointHoverRadius:18,
    }));
    note='One point per adapter — all selected models & cases summed.';
    showLabels=true;

  } else if(S.scatterMode==='by-model'){
    const agg=aggByModel(rows);
    yMax=Math.max(...agg.map(g=>g.total),1);
    const byFam={};
    for(const g of agg)(byFam[g.model.split('/')[0]]=byFam[g.model.split('/')[0]]||[]).push(g);
    datasets=Object.entries(byFam).map(([fam,items])=>({
      label:fam,
      data:items.map(g=>({x:g.secs,y:g.pass,_g:g,_type:'model'})),
      backgroundColor:items.map(g=>fc(g.model)+'cc'),
      borderColor:items.map(g=>fc(g.model)),
      borderWidth:2,
      pointStyle:items.map(g=>pdef(g.model).style),
      rotation:items.map(g=>pdef(g.model).rot),
      pointRadius:12,pointHoverRadius:16,
    }));
    note='One point per model — all adapters summed. Shape = model (same symbol as filter chips).';
    showLabels=true;

  } else {
    const agg=aggregated(rows);
    yMax=[...S.cases].reduce((s,c)=>s+(CASE_TOTALS[c]||0),0)||1;
    const byAdapter={};
    for(const g of agg)(byAdapter[g.adapter]=byAdapter[g.adapter]||[]).push(g);
    datasets=Object.entries(byAdapter).map(([adapter,items])=>({
      label:adapter,
      data:items.map(g=>({x:g.secs,y:g.pass,_g:g,_type:'detail'})),
      backgroundColor:ac(adapter)+'cc',borderColor:ac(adapter),
      borderWidth:2,
      pointStyle:items.map(g=>pdef(g.model).style),
      rotation:items.map(g=>pdef(g.model).rot),
      pointRadius:9,pointHoverRadius:13,
    }));
    note='Color = adapter · Shape = model (same symbol as filter chips). Each point = adapter × model.';
    showLabels=false;
  }

  document.getElementById('scatter-note').textContent=note;

  C1=new Chart(document.getElementById('C1'),{
    type:'scatter',
    data:{datasets},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{position:'top'},
        datalabels:{
          display:showLabels,
          formatter:val=>{
            const g=val._g;
            if(val._type==='adapter') return g.adapter+'\n'+fmtFrac(g.pass,g.total);
            if(val._type==='model')   return sym(g.model)+' '+shortModel(g.model)+'\n'+fmtFrac(g.pass,g.total);
            return fmtFrac(g.pass,g.total);
          },
          font:{size:10,weight:'600'},color:'#1f2328',
          align:'top',offset:8,textAlign:'center',
        },
        tooltip:{
          callbacks:{
            title:ctx=>{
              const g=ctx[0].raw._g, t=ctx[0].raw._type;
              return t==='adapter'?g.adapter:sym(g.model)+' '+shortModel(g.model);
            },
            label:ctx=>{
              const g=ctx[0].raw._g, t=ctx[0].raw._type;
              const sz=t!=='adapter'?parseSize(g.model):null;
              const lines=[];
              if(t==='detail')   lines.push(`  adapter: ${g.adapter}`);
              if(t!=='adapter')  lines.push(`  model:   ${g.model}`);
              if(sz!=null)       lines.push(`  size:    ${sz}B`);
              lines.push(`  score:   ${fmtFrac(g.pass,g.total)}`);
              lines.push(`  time:    ${fmtTime(g.secs)}`);
              if(g.attempted!=null&&g.attempted<g.caseCount)
                lines.push(`  ⚠ ${g.attempted}/${g.caseCount} cases run`);
              return lines;
            }
          }
        }
      },
      scales:{
        x:{title:{display:true,text:'Total seconds  ←  lower is better'},grid:{color:'#eaeef2'}},
        y:{title:{display:true,text:'Checks passed'},min:0,max:yMax,
           ticks:{stepSize:Math.max(1,Math.round(yMax/6)),callback:v=>Number.isInteger(v)?v+'/'+yMax:''},
           grid:{color:'#eaeef2'}}
      }
    }
  });
}

// ─── View 2: Heatmap ────────────────────────────────────
function vHeatmap(el,rows){
  const cases=[...S.cases].sort();
  const gb=S.hmGroupBy;
  const detailMode=gb==='none'?'all':S.groupedDetail;
  const showGrouped=gb!=='none'&&detailMode==='overall';
  const agg=showGrouped
    ?aggregateGroupRows(rows,gb)
    :detailMode==='top5'
      ?topModelsByGroup(rows,gb,5)
      :aggregated(rows,gb);
  const maxSec=Math.max(...rows.map(r=>r.seconds).filter(Boolean),1);
  const mMode=(label,mode)=>
    `<button class="btn${S.hmMode===mode?' on':''}" onclick="S.hmMode='${mode}';render()">${label}</button>`;
  const gBtn=(label,g)=>
    `<button class="btn${S.hmGroupBy===g?' on':''}" onclick="S.hmGroupBy='${g}';render()">${label}</button>`;
  const dBtn=(label,mode)=>
    `<button class="btn${S.groupedDetail===mode?' on':''}" onclick="S.groupedDetail='${mode}';render()">${label}</button>`;
  let html=`<div class="card">
  <div class="ctrl-row">${mMode('Score','score')} ${mMode('Time','time')}
    <div class="ctrl-sep"></div>
    ${gBtn('By Adapter','adapter')} ${gBtn('By Runtime','runtime')} ${gBtn('Adap+RT','adapter+runtime')}
    <div class="ctrl-sep"></div>
    ${dBtn('Overall','overall')} ${dBtn('Top 5 models','top5')} ${dBtn('All models','all')}
    <div class="ctrl-sep"></div>
    <span class="row-count">${showGrouped?'Grouped totals across selected models.':detailMode==='top5'?'Top 5 models per group.':'All selected models shown — missing (—) counted as 0'}</span>
  </div>
  <div class="hm-wrap"><table class="hm"><thead><tr>
    <th class="rl" style="z-index:3">${showGrouped?'Group':'Model'}</th>
    <th class="agg">${S.hmMode==='score'?'Total':'Total time'}</th>
    ${cases.map(c=>`<th title="${c}">${c.replace(/^\w+-\d+-/,'')}</th>`).join('')}
  </tr></thead><tbody>`;
  let lastGroup=null;
  for(const g of agg){
    const groupVal=groupKey(g,gb);
    if(groupVal!==lastGroup){
      lastGroup=groupVal;
      const hdr=groupHeader(g,gb);
      const dotHtml=showGrouped?'':hdr.dotHtml;
      const groupLabel=hdr.label;
      html+=`<tr class="adapter-hdr"><td colspan="${cases.length+2}">${dotHtml}${groupLabel}</td></tr>`;
    }
    const aggBg=S.hmMode==='score'?scoreColor(g.avgScore):timeColor(g.secs,maxSec*cases.length);
    const aggVal=S.hmMode==='score'?fmtFrac(g.pass,g.total):fmtTime(g.secs);
    const inlineRt=!showGrouped&&gb==='adapter'&&g.runtime
      ?` <span style="font-size:9px;background:#f0f4ff;color:#0969da;padding:1px 4px;border-radius:3px;border:1px solid #b6d0f7;vertical-align:middle">${g.runtime}</span>`:'';
    const inlineAd=!showGrouped&&gb==='runtime'
      ?` <span style="font-size:10px;color:${ac(g.adapter)};vertical-align:middle"> · ${g.adapter}</span>`:'';
    let rowLabel='', rowTitle='', totalTitle='';
    if(showGrouped){
      const top=g.topModels.map(m=>`${shortModel(m.model)} ${fmtFrac(m.pass,m.total)}`).join(' · ');
      rowLabel=`Overall <span style="font-size:10px;color:var(--muted);font-weight:400">${g.modelCount} models</span>`;
      rowTitle=`${g.adapter}${g.runtime?' · '+g.runtime:''} · ${g.modelCount} models`;
      totalTitle=`${fmtFrac(g.pass,g.total)} checks · top: ${top||'—'}`;
    } else {
      const sz=parseSize(g.model);
      rowLabel=`${sym(g.model)} ${shortModel(g.model)} <span style="font-size:10px;color:var(--muted);font-weight:400">${sz?sz+'B':''}</span>${inlineRt}${inlineAd}`;
      rowTitle=`${g.model} · ${sz?sz+'B':'?'} · ${g.adapter}${g.runtime?' · '+g.runtime:''}`;
      totalTitle=fmtFrac(g.pass,g.total)+' checks';
      if(g.attempted<g.caseCount) totalTitle+=` ⚠${g.attempted}/${g.caseCount}`;
    }
    html+=`<tr>
      <td class="rl" title="${rowTitle}">${rowLabel}</td>
      <td class="agg" style="background:${aggBg}" title="${totalTitle}">${aggVal}</td>`;
    for(const c of cases){
      const r=g.byCase[c];
      if(!r||!r.total){html+=`<td style="background:#f0f2f4;color:#adb5bd" title="not run">—</td>`;continue;}
      if(showGrouped){
        const score=r.total?r.pass/r.total:0;
        const bg=S.hmMode==='score'?scoreColor(score):timeColor(r.secs,maxSec*Math.max(r.n,1));
        const warn=r.timeout?';outline:2px solid #6e40c9;outline-offset:-2px':'';
        const title=`${fmtFrac(r.pass,r.total)} · ${fmtTime(r.secs)} · ${r.n} models`;
        html+=`<td style="background:${bg}${warn}" title="${title}">${S.hmMode==='score'?fmtFrac(r.pass,r.total):fmtTime(r.secs)}</td>`;
      } else {
        const bg=S.hmMode==='score'?scoreColor(r.score):timeColor(r.seconds,maxSec);
        const out=r.status.includes('timeout')?';outline:2px solid #6e40c9;outline-offset:-2px':'';
        html+=`<td style="background:${bg}${out}" title="${r.pass}/${r.total} · ${fmtTime(r.seconds)} · ${r.status}">${S.hmMode==='score'?fmtFrac(r.pass,r.total):fmtTime(r.seconds)}</td>`;
      }
    }
    html+=`</tr>`;
  }
  html+=`</tbody></table></div></div>`;
  el.innerHTML=html;
}

// ─── View 3: Bars ───────────────────────────────────────
function vBars(el,rows){
  const agg=aggregated(rows);
  const models=[...new Set(agg.map(g=>g.model))].sort();
  const adapters=[...new Set(agg.map(g=>g.adapter))].sort();
  const mBtn=(label,mode)=>
    `<button class="btn${S.barMode===mode?' on':''}" onclick="S.barMode='${mode}';render()">${label}</button>`;
  el.innerHTML=`<div class="card">
  <div class="ctrl-row">${mBtn('Score','score')} ${mBtn('Time','time')}</div>
  <div class="chart-wrap"><canvas id="C1"></canvas></div></div>`;
  C1=new Chart(document.getElementById('C1'),{
    type:'bar',
    data:{
      labels:models.map(m=>sym(m)+' '+shortModel(m)),
      datasets:adapters.map(adapter=>({
        label:adapter,
        data:models.map(m=>{const g=agg.find(x=>x.adapter===adapter&&x.model===m);return g?(S.barMode==='score'?g.avgScore:g.secs):null;}),
        backgroundColor:ac(adapter)+'bb',borderColor:ac(adapter),borderWidth:1,
      }))
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{position:'top'},
        tooltip:{callbacks:{label:ctx=>{
          const g=agg.find(x=>x.adapter===ctx.dataset.label&&sym(x.model)+' '+shortModel(x.model)===ctx.label);
          if(!g)return`${ctx.dataset.label}: —`;
          return S.barMode==='score'?`${ctx.dataset.label}: ${fmtFrac(g.pass,g.total)}`:`${ctx.dataset.label}: ${fmtTime(g.secs)}`;
        }}}
      },
      scales:{
        x:{grid:{display:false},ticks:{maxRotation:40}},
        y:{title:{display:true,text:S.barMode==='score'?'Avg score (missing=0)':'Total seconds'},
          ...(S.barMode==='score'?{min:0,max:1.06,ticks:{callback:v=>v<=1?fmtPct(v):''}}:{}),
          grid:{color:'#eaeef2'}}
      }
    }
  });
}

// ─── View 4: Leaderboard ────────────────────────────────
function vLeaderboard(el,rows){
  const gb=S.lbGroupBy;
  const detailMode=gb==='none'?'all':S.groupedDetail;
  const showGrouped=gb!=='none'&&detailMode==='overall';
  const agg=showGrouped
    ?aggregateGroupRows(rows,gb)
    :detailMode==='top5'
      ?topModelsByGroup(rows,gb,5)
      :aggregated(rows,gb);
  const cases=[...S.cases].sort();
  const gBtn=(label,v)=>
    `<button class="btn${S.lbGroupBy===v?' on':''}" onclick="S.lbGroupBy='${v}';render()">${label}</button>`;
  const dBtn=(label,mode)=>
    `<button class="btn${S.groupedDetail===mode?' on':''}" onclick="S.groupedDetail='${mode}';render()">${label}</button>`;
  let html=`<div class="ctrl-row" style="margin-bottom:10px">${gBtn('All','none')} ${gBtn('By Adapter','adapter')} ${gBtn('By Runtime','runtime')} ${gBtn('Adap+RT','adapter+runtime')} <div class="ctrl-sep"></div> ${dBtn('Overall','overall')} ${dBtn('Top 5 models','top5')} ${dBtn('All models','all')}</div><div class="lb">`;
  let lastGroup=null, groupI=-1;
  agg.forEach((g,globalI)=>{
    const groupVal=gb!=='none'?groupKey(g,gb):null;
    if(groupVal!==null&&groupVal!==lastGroup){
      lastGroup=groupVal; groupI=0;
      const pad=globalI>0?'padding-top:16px':'';
      const info=groupHeader(g,gb);
      const hdr=`<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;${pad};padding-bottom:4px;color:${info.color}">${info.dotHtml}${gb==='runtime'?'Runtime: ':''}${info.label}</div>`;
      html+=hdr;
    } else {
      groupI++;
    }
    const rankI=gb==='none'?globalI:groupI;
    const rc=rankColor(rankI),sc=scoreCol(g.avgScore);
    let title='',sub='',tags='',coverage='';
    if(showGrouped){
      const top=g.topModels.map(m=>`${sym(m.model)} ${shortModel(m.model)} ${fmtFrac(m.pass,m.total)}`).join(' · ');
      title=`Overall <span style="font-size:10px;font-weight:400;color:var(--muted)">${g.modelCount} models</span>`;
      sub=`Top models: ${top||'—'}`;
      tags=cases.map(c=>{
        const r=g.byCase[c];
        if(!r||!r.total)return`<span class="lb-case" style="background:#f0f2f4;color:#9ca3af" title="not run">${c.replace(/^\w+-\d+-/,'')}</span>`;
        const score=r.pass/r.total, bg=scoreColor(score), col=scoreCol(score);
        const to=r.timeout?' style="outline:1px solid #6e40c9"':'';
        return`<span class="lb-case" style="background:${bg};color:${col}"${to}>${c.replace(/^\w+-\d+-/,'')} ${fmtFrac(r.pass,r.total)}</span>`;
      }).join('');
      coverage=`${g.modelCount} models selected`;
    } else {
      const sz=parseSize(g.model);
      const showAdapter=gb!=='adapter'&&gb!=='adapter+runtime';
      const showRuntime=gb!=='runtime'&&gb!=='adapter+runtime';
      const abadge=showAdapter?`<span class="badge" style="background:${ac(g.adapter)}22;color:${ac(g.adapter)};border:1px solid ${ac(g.adapter)}44">${g.adapter}</span>`:'';
      const rbadge=showRuntime?rtBadge(g):'';
      const covCol=g.attempted<g.caseCount?'#d4371c':'var(--muted)';
      title=`${sym(g.model)} ${shortModel(g.model)} <span style="font-size:10px;font-weight:400;color:var(--muted)">${sz?sz+'B':''}</span>`;
      sub=`${g.model} ${abadge}${rbadge}`;
      tags=cases.map(c=>{
        const r=g.byCase[c];
        if(!r)return`<span class="lb-case" style="background:#f0f2f4;color:#9ca3af" title="not run">${c.replace(/^\w+-\d+-/,'')}</span>`;
        const bg=scoreColor(r.score),col=scoreCol(r.score);
        const to=r.status.includes('timeout')?' style="outline:1px solid #6e40c9"':'';
        return`<span class="lb-case" style="background:${bg};color:${col}"${to}>${c.replace(/^\w+-\d+-/,'')} ${fmtFrac(r.pass,r.total)}</span>`;
      }).join('');
      coverage=`<span style="color:${covCol}">${g.attempted}/${g.caseCount} cases run</span>`;
    }
    html+=`<div class="lb-row">
      <div class="lb-rank" style="color:${rc}">#${rankI+1}</div>
      <div>
        <div class="lb-model">${title}</div>
        <div class="lb-sub">${sub}</div>
        <div class="lb-cases">${tags}</div>
      </div>
      <div class="lb-right">
        <div class="lb-score" style="color:${sc}">${fmtFrac(g.pass,g.total)}</div>
        <div class="lb-time">${fmtTime(g.secs)}</div>
        <div class="lb-coverage">${coverage}</div>
      </div>
    </div>`;
  });
  html+='</div>';
  el.innerHTML=`<div class="card" style="padding:12px">${html}</div>`;
}

// ─── View 5: Table ──────────────────────────────────────
function vTable(el,rows){
  const cols=[
    {k:'run',label:'Run'},{k:'adapter',label:'Adapter'},{k:'model',label:'Model'},
    {k:'runtime',label:'Runtime'},{k:'case',label:'Case'},{k:'score',label:'Score'},
    {k:'seconds',label:'Time'},{k:'pass',label:'Pass'},{k:'total',label:'Total'},{k:'status',label:'Status'},
  ];
  const{col:sc,dir:sd}=S.tblSort;
  const q=S.tblSearch.toLowerCase();
  let sorted=rows.filter(r=>!q||[r.run,r.adapter,r.model,r.runtime,r.case,r.status].some(v=>String(v).toLowerCase().includes(q)));
  sorted.sort((a,b)=>{const av=a[sc],bv=b[sc];const cmp=typeof av==='number'?av-bv:String(av).localeCompare(String(bv));return sd==='asc'?cmp:-cmp;});
  el.innerHTML=`<div class="card">
  <div class="ctrl-row">
    <input class="search" id="tbl-q" placeholder="Search run, adapter, model, case…" value="${S.tblSearch}">
    <span class="row-count">${sorted.length} rows</span>
    <div class="ctrl-sep"></div>
    <button class="btn" onclick="S.tblSearch='';document.getElementById('tbl-q').value='';render()">Clear</button>
  </div>
  <div class="dt-wrap"><table class="dt">
  <thead><tr>${cols.map(c=>`<th class="${sc===c.k?(sd==='asc'?'sa':'sd'):''}" data-col="${c.k}">${c.label}</th>`).join('')}</tr></thead>
  <tbody>
  ${sorted.map(r=>{const sz=parseSize(r.model);return`<tr>
    <td style="font-size:11px;color:var(--muted)">${r.run}</td>
    <td><span class="adot" style="background:${ac(r.adapter)}"></span>${r.adapter}</td>
    <td title="${r.model}">${sym(r.model)} ${shortModel(r.model)} <span style="font-size:10px;color:var(--muted)">${sz?sz+'B':''}</span></td>
    <td style="font-size:11px;color:var(--muted)">${r.runtime||'—'}</td>
    <td>${r.case}</td>
    <td style="background:${scoreColor(r.score)};font-weight:600">${fmtFrac(r.pass,r.total)}</td>
    <td>${fmtTime(r.seconds)}</td>
    <td>${r.pass}</td><td>${r.total}</td>
    <td>${statusBadge(r.status)}</td>
  </tr>`;}).join('')}
  </tbody></table></div></div>`;
  document.getElementById('tbl-q').addEventListener('input',e=>{S.tblSearch=e.target.value;render();});
  document.querySelectorAll('.dt th[data-col]').forEach(th=>{
    th.addEventListener('click',()=>{
      const k=th.dataset.col;
      S.tblSort=S.tblSort.col===k?{col:k,dir:S.tblSort.dir==='asc'?'desc':'asc'}:{col:k,dir:'asc'};
      render();
    });
  });
}

// ─── View 6: By Task ────────────────────────────────────
function vByTask(el,rows){
  const cases=[...new Set(rows.map(r=>r.case))].sort();
  function rankForCase(c){
    const map=new Map();
    for(const r of rows.filter(x=>x.case===c)){
      const k=r.adapter+'|'+r.model,cur=map.get(k);
      if(!cur||r.score>cur.score||(r.score===cur.score&&r.seconds<cur.seconds))map.set(k,r);
    }
    return[...map.values()].sort((a,b)=>b.score-a.score||a.seconds-b.seconds);
  }
  const langTag=c=>({bash:'sh',js:'js',ts:'ts',smoke:'—'})[c.split('-')[0]]||c.split('-')[0];
  let html='<div class="task-grid">';
  for(const c of cases){
    const ranked=rankForCase(c);
    html+=`<div class="task-card">
      <div class="task-title"><span class="task-tag">${langTag(c)}</span>${c}</div>`;
    if(!ranked.length){html+=`<div style="color:var(--muted);font-size:12px;padding:8px 0">No data</div>`;}
    else ranked.forEach((r,i)=>{
      const rc=rankColor(i),bg=scoreColor(r.score),col=scoreCol(r.score);
      const sz=parseSize(r.model);
      const to=r.status.includes('timeout')?' title="timeout" style="outline:1px solid #6e40c9"':'';
      html+=`<div class="task-row">
        <span class="task-rank" style="color:${rc}">#${i+1}</span>
        <span style="font-size:13px;flex-shrink:0">${sym(r.model)}</span>
        <span class="task-model" title="${r.model} · ${sz?sz+'B':'?'}">${shortModel(r.model)}</span>
        <span class="task-adapter" style="background:${ac(r.adapter)}18;color:${ac(r.adapter)}">${r.adapter}</span>
        ${r.runtime?`<span class="task-adapter" style="background:#f0f4ff;color:#0969da">${r.runtime}</span>`:''}
        <span class="task-score" style="background:${bg};color:${col}"${to}>${fmtFrac(r.pass,r.total)}</span>
        <span class="task-time">${fmtTime(r.seconds)}</span>
      </div>`;
    });
    html+=`</div>`;
  }
  html+='</div>';
  el.innerHTML=html;
}

init();
</script>
</body>
</html>
VIZ_END
} > "$OUT"

bytes=$(wc -c < "$OUT" | tr -d ' ')
ok "results/index.html written (${bytes} bytes, ${#csvs[@]} run dirs)"

