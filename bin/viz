#!/usr/bin/env bash
# bin/viz — regenerate results/index.html from all run CSVs (adapter × model × case).
# Usage: bin/viz
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
source "$HERE/config.sh"; source "$HERE/lib/common.sh"

OUT="$HERE/results/index.html"
PROTO_OUT="$HERE/results/compare-agents.html"

mapfile -t csvs < <(find "$RESULTS_DIR" -name 'results.csv' | sort)
[ "${#csvs[@]}" -gt 0 ] || die "no results.csv found in $RESULTS_DIR"
info "Building index.html from ${#csvs[@]} run(s)…"

# ── JSON data array (one object per CSV row, run field added from dir name) ──
data_json=$(awk -F, '
  BEGIN { printf "["; sep="" }
  FNR==1 { n=split(FILENAME,a,"/"); run=a[n-1]; next }
  {
    st=$8; gsub(/\\/,"\\\\",st); gsub(/"/,"\\\"",st)
    mo=$2; gsub(/\\/,"\\\\",mo); gsub(/"/,"\\\"",mo)
    rt=$10; gsub(/\\/,"\\\\",rt); gsub(/"/,"\\\"",rt)
    printf "%s{\"run\":\"%s\",\"adapter\":\"%s\",\"model\":\"%s\",\"case\":\"%s\",\"pass\":%d,\"total\":%d,\"score\":%s,\"seconds\":%d,\"status\":\"%s\",\"trials\":%d,\"runtime\":\"%s\"}",
      sep, run, $1, mo, $3, $4+0, $5+0, $6, $7+0, st, ($9+0<1?1:$9+0), rt
    sep=","
  }
  END { printf "]" }
' "${csvs[@]}")

# ── CASE_TOTALS: max 'total' seen per case ───────────────────────────────────
case_totals_json=$(awk -F, '
  FNR>1 { if($5+0 > ct[$3]+0) ct[$3]=$5+0 }
  END {
    sep=""
    printf "{"
    for(c in ct){ printf "%s\"%s\":%d", sep, c, ct[c]+0; sep="," }
    printf "}"
  }
' "${csvs[@]}")

# ── Write HTML ────────────────────────────────────────────────────────────────
{
cat << 'VIZ_END'
<!DOCTYPE html>
